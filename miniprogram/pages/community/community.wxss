.community {
  min-height: 100vh;
  padding: 0 16rpx 170rpx;
  background: #f8f7f5;
}

.feed-sticky {
  position: sticky;
  top: 0;
  z-index: 8;
  margin: 0 -16rpx 16rpx;
  padding: 18rpx 16rpx 0;
  background: rgba(248, 247, 245, 0.97);
  border-bottom: 1rpx solid rgba(15, 23, 42, 0.04);
  backdrop-filter: blur(16rpx);
}

.topbar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.brand-title {
  flex: none;
  color: #111827;
  font-size: 39rpx;
  font-weight: 900;
}

.search-pill {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
  height: 62rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 1rpx solid rgba(15, 23, 42, 0.04);
  box-sizing: border-box;
}

.search-icon {
  position: relative;
  width: 28rpx;
  height: 28rpx;
  margin-right: 10rpx;
  border: 4rpx solid #9ca3af;
  border-radius: 50%;
  box-sizing: border-box;
}

.search-icon::after {
  content: "";
  position: absolute;
  right: -8rpx;
  bottom: -7rpx;
  width: 12rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: #9ca3af;
  transform: rotate(45deg);
}

.search-pill input {
  flex: 1;
  height: 62rpx;
  color: #111827;
  font-size: 26rpx;
}

.search-pill text {
  width: 40rpx;
  color: #94a3b8;
  font-size: 36rpx;
  text-align: right;
}

.search-panel {
  margin: 0 0 14rpx;
  padding: 18rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 22rpx rgba(15, 23, 42, 0.045);
}

.search-panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #64748b;
  font-size: 23rpx;
  font-weight: 800;
}

.search-panel-head text:last-child {
  color: #ff4d5f;
}

.recent-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.recent-chip {
  max-width: 280rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #faf9f7;
  color: #334155;
  font-size: 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.search-state {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin: 0 0 12rpx;
  padding: 14rpx 18rpx;
  border-radius: 18rpx;
  background: #fff1f3;
  color: #9f1239;
  font-size: 24rpx;
  font-weight: 800;
}

.search-state text:first-child {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.channel-scroll {
  white-space: nowrap;
  margin: 0 -16rpx;
}

.channel-row {
  display: flex;
  gap: 34rpx;
  padding: 0 16rpx;
}

.channel {
  position: relative;
  flex: none;
  padding: 12rpx 0 17rpx;
  color: #64748b;
  font-size: 28rpx;
  font-weight: 700;
}

.channel.active {
  color: #111827;
  font-weight: 900;
}

.channel.active::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: 4rpx;
  width: 30rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: #ff4d5f;
  transform: translateX(-50%);
}

.waterfall {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.community-empty {
  padding-top: 80rpx;
}

.ask-btn {
  width: 220rpx;
  height: 68rpx;
  margin: 28rpx auto 0;
  border-radius: 999rpx;
  background: #ff4d5f;
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 68rpx;
}

.ask-btn::after {
  border: 0;
}

.waterfall-col {
  flex: 1;
  min-width: 0;
}

.note-card {
  margin-bottom: 14rpx;
  overflow: hidden;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 26rpx rgba(15, 23, 42, 0.045);
}

.cover-wrap {
  position: relative;
  min-height: 230rpx;
  background: #f3f4f6;
}

.note-cover {
  width: 100%;
  display: block;
}

.video-badge {
  position: absolute;
  right: 12rpx;
  top: 12rpx;
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
  background: rgba(17, 24, 39, 0.66);
}

.video-badge::before {
  content: "";
  position: absolute;
  left: 18rpx;
  top: 13rpx;
  width: 0;
  height: 0;
  border-top: 10rpx solid transparent;
  border-bottom: 10rpx solid transparent;
  border-left: 15rpx solid #ffffff;
}

.cover-flags {
  position: absolute;
  left: 12rpx;
  right: 12rpx;
  bottom: 12rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.cover-flags text {
  height: 30rpx;
  line-height: 30rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: rgba(17, 24, 39, 0.66);
  color: #ffffff;
  font-size: 19rpx;
  font-weight: 800;
}

.poster-cover {
  position: relative;
  min-height: 306rpx;
  display: flex;
  align-items: center;
  padding: 34rpx 26rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.poster-mint {
  background: #effcf5;
}

.poster-lemon {
  background: #fff9d7;
}

.poster-rose {
  background: #fff0f4;
}

.poster-sky {
  background: #eff6ff;
}

.poster-paper {
  background: #f8f1e8;
}

.poster-title {
  position: relative;
  color: #222222;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.28;
  letter-spacing: 0;
  display: -webkit-box;
  -webkit-line-clamp: 4;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.note-body {
  padding: 16rpx 16rpx 18rpx;
}

.flag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 7rpx;
  margin-top: 9rpx;
}

.flag-row text {
  height: 27rpx;
  line-height: 27rpx;
  padding: 0 9rpx;
  border-radius: 999rpx;
  background: #fff1f3;
  color: #ef4056;
  font-size: 18rpx;
  font-weight: 800;
}

.note-title {
  color: #111827;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.36;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.note-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
  margin-top: 16rpx;
  color: #7b8494;
  font-size: 22rpx;
}

.author {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex: 1;
  min-width: 0;
}

.author text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.avatar {
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  background: #fff1f3;
  flex: none;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ff4d5f;
  font-size: 19rpx;
  font-weight: 800;
}

.like {
  flex: none;
  display: flex;
  align-items: center;
  gap: 4rpx;
  color: #6b7280;
  font-size: 23rpx;
}

.like.active {
  color: #ff4d5f;
  font-weight: 800;
}
