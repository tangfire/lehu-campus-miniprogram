.community {
  min-height: 100vh;
  padding: 0 14rpx 170rpx;
  background: #f7f8fa;
}

.feed-sticky {
  position: sticky;
  top: 0;
  z-index: 8;
  margin: 0 -14rpx 14rpx;
  padding: 16rpx 14rpx 0;
  background: rgba(247, 248, 250, 0.98);
  border-bottom: 1rpx solid rgba(15, 23, 42, 0.04);
}

.topbar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.brand-title {
  flex: none;
  color: #111827;
  font-size: 40rpx;
  font-weight: 900;
}

.search-pill {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
  height: 62rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.search-icon {
  position: relative;
  width: 28rpx;
  height: 28rpx;
  margin-right: 10rpx;
  border: 4rpx solid #9ca3af;
  border-radius: 50%;
  box-sizing: border-box;
}

.search-icon::after {
  content: "";
  position: absolute;
  right: -8rpx;
  bottom: -7rpx;
  width: 12rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: #9ca3af;
  transform: rotate(45deg);
}

.search-pill input {
  flex: 1;
  height: 62rpx;
  color: #111827;
  font-size: 26rpx;
}

.search-pill text {
  width: 40rpx;
  color: #94a3b8;
  font-size: 36rpx;
  text-align: right;
}

.channel-scroll {
  white-space: nowrap;
  margin: 0 -14rpx;
}

.channel-row {
  display: flex;
  gap: 36rpx;
  padding: 0 14rpx;
}

.channel {
  position: relative;
  flex: none;
  padding: 12rpx 0 17rpx;
  color: #64748b;
  font-size: 29rpx;
  font-weight: 700;
}

.channel.active {
  color: #111827;
  font-weight: 900;
}

.channel.active::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: 4rpx;
  width: 30rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: #ef4056;
  transform: translateX(-50%);
}

.waterfall {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.waterfall-col {
  flex: 1;
  min-width: 0;
}

.note-card {
  margin-bottom: 12rpx;
  overflow: hidden;
  border-radius: 12rpx;
  background: #ffffff;
  box-shadow: none;
}

.cover-wrap {
  position: relative;
  min-height: 230rpx;
  background: #f1f5f9;
}

.note-cover {
  width: 100%;
  display: block;
}

.video-badge {
  position: absolute;
  right: 12rpx;
  top: 12rpx;
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
  background: rgba(17, 24, 39, 0.66);
}

.video-badge::before {
  content: "";
  position: absolute;
  left: 18rpx;
  top: 13rpx;
  width: 0;
  height: 0;
  border-top: 10rpx solid transparent;
  border-bottom: 10rpx solid transparent;
  border-left: 15rpx solid #ffffff;
}

.cover-flags {
  position: absolute;
  left: 12rpx;
  right: 12rpx;
  bottom: 12rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.cover-flags text {
  height: 30rpx;
  line-height: 30rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: rgba(17, 24, 39, 0.66);
  color: #ffffff;
  font-size: 19rpx;
  font-weight: 800;
}

.poster-cover {
  position: relative;
  min-height: 318rpx;
  padding: 28rpx 24rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.poster-mint {
  background: #effcf5;
}

.poster-lemon {
  background: #fff9d7;
}

.poster-rose {
  background: #fff0f4;
}

.poster-sky {
  background: #eff6ff;
}

.poster-paper {
  background: #f8f1e8;
}

.poster-kicker {
  position: relative;
  display: inline-block;
  max-width: 100%;
  margin-bottom: 22rpx;
  padding: 7rpx 13rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #0f766e;
  font-size: 21rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.poster-title {
  position: relative;
  color: #222222;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.28;
  letter-spacing: 0;
  display: -webkit-box;
  -webkit-line-clamp: 4;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.note-body {
  padding: 14rpx 14rpx 16rpx;
}

.flag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 7rpx;
  margin-top: 9rpx;
}

.flag-row text {
  height: 27rpx;
  line-height: 27rpx;
  padding: 0 9rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  color: #0f766e;
  font-size: 18rpx;
  font-weight: 800;
}

.note-title {
  color: #111827;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.36;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.note-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
  margin-top: 14rpx;
  color: #7b8494;
  font-size: 22rpx;
}

.author {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex: 1;
  min-width: 0;
}

.author text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.avatar {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #e0f2fe;
  flex: none;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #0f766e;
  font-size: 19rpx;
  font-weight: 800;
}

.like {
  flex: none;
  color: #6b7280;
  font-size: 23rpx;
}
