.community {
  min-height: 100vh;
  padding: 0 12rpx 170rpx;
  background: #fafafa;
}

.feed-sticky {
  position: sticky;
  top: 0;
  z-index: 8;
  margin: 0 -12rpx 12rpx;
  padding: 18rpx 12rpx 0;
  background: rgba(250, 250, 250, 0.96);
  backdrop-filter: blur(18rpx);
}

.topbar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.brand-title {
  flex: none;
  color: #111827;
  font-size: 44rpx;
  font-weight: 900;
}

.search-pill {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
  height: 64rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #f2f3f5;
  box-sizing: border-box;
}

.search-icon {
  position: relative;
  width: 28rpx;
  height: 28rpx;
  margin-right: 10rpx;
  border: 4rpx solid #9ca3af;
  border-radius: 50%;
  box-sizing: border-box;
}

.search-icon::after {
  content: "";
  position: absolute;
  right: -8rpx;
  bottom: -7rpx;
  width: 12rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: #9ca3af;
  transform: rotate(45deg);
}

.search-pill input {
  flex: 1;
  height: 64rpx;
  color: #111827;
  font-size: 26rpx;
}

.search-pill text {
  width: 40rpx;
  color: #94a3b8;
  font-size: 36rpx;
  text-align: right;
}

.channel-scroll {
  white-space: nowrap;
  margin: 0 -12rpx;
}

.channel-row {
  display: flex;
  gap: 42rpx;
  padding: 0 12rpx;
}

.channel {
  position: relative;
  flex: none;
  padding: 13rpx 0 20rpx;
  color: #64748b;
  font-size: 30rpx;
  font-weight: 700;
}

.channel.active {
  color: #111827;
  font-weight: 900;
}

.channel.active::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: 4rpx;
  width: 34rpx;
  height: 7rpx;
  border-radius: 999rpx;
  background: #ef4056;
  transform: translateX(-50%);
}

.waterfall {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
}

.waterfall-col {
  flex: 1;
  min-width: 0;
}

.note-card {
  margin-bottom: 10rpx;
  overflow: hidden;
  border-radius: 10rpx;
  background: #ffffff;
  box-shadow: 0 1rpx 0 rgba(15, 23, 42, 0.035);
}

.cover-wrap {
  position: relative;
  min-height: 250rpx;
  background: #f1f5f9;
}

.note-cover {
  width: 100%;
  display: block;
}

.video-badge {
  position: absolute;
  right: 12rpx;
  top: 12rpx;
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
  background: rgba(17, 24, 39, 0.66);
}

.video-badge::before {
  content: "";
  position: absolute;
  left: 18rpx;
  top: 13rpx;
  width: 0;
  height: 0;
  border-top: 10rpx solid transparent;
  border-bottom: 10rpx solid transparent;
  border-left: 15rpx solid #ffffff;
}

.cover-flags {
  position: absolute;
  left: 12rpx;
  right: 12rpx;
  bottom: 12rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.cover-flags text {
  height: 30rpx;
  line-height: 30rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: rgba(17, 24, 39, 0.66);
  color: #ffffff;
  font-size: 19rpx;
  font-weight: 800;
}

.poster-cover {
  position: relative;
  min-height: 352rpx;
  padding: 30rpx 24rpx 24rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.poster-mint {
  background: linear-gradient(160deg, #f7fff6 0%, #e5fff4 48%, #d6f3f0 100%);
}

.poster-lemon {
  background: linear-gradient(160deg, #ffffe9 0%, #fff8bd 54%, #fffdf1 100%);
}

.poster-rose {
  background: linear-gradient(160deg, #fff5f6 0%, #ffdbe3 54%, #fff8fa 100%);
}

.poster-sky {
  background: linear-gradient(160deg, #f4f9ff 0%, #d7e9ff 54%, #f9fcff 100%);
}

.poster-paper {
  background: linear-gradient(160deg, #fffaf2 0%, #f2e7d6 54%, #fffdf8 100%);
}

.poster-quote {
  position: absolute;
  left: 20rpx;
  top: 18rpx;
  color: rgba(255, 255, 255, 0.68);
  font-size: 122rpx;
  font-weight: 900;
  line-height: 1;
}

.poster-orbit {
  position: absolute;
  border-radius: 50%;
  opacity: 0.46;
  pointer-events: none;
}

.poster-orbit.one {
  right: -42rpx;
  top: -38rpx;
  width: 136rpx;
  height: 136rpx;
  background: rgba(255, 255, 255, 0.64);
}

.poster-orbit.two {
  left: -32rpx;
  bottom: -34rpx;
  width: 112rpx;
  height: 112rpx;
  background: rgba(255, 255, 255, 0.5);
}

.poster-kicker {
  position: relative;
  display: inline-block;
  max-width: 100%;
  margin-top: 38rpx;
  margin-bottom: 18rpx;
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.68);
  color: #0f766e;
  font-size: 21rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.poster-title {
  position: relative;
  color: #333333;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1.24;
  letter-spacing: 0;
  display: -webkit-box;
  -webkit-line-clamp: 4;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.poster-mark {
  position: absolute;
  right: 22rpx;
  bottom: 28rpx;
  width: 48rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: rgba(239, 64, 86, 0.42);
}

.note-body {
  padding: 14rpx 14rpx 16rpx;
}

.flag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 7rpx;
  margin-top: 9rpx;
}

.flag-row text {
  height: 27rpx;
  line-height: 27rpx;
  padding: 0 9rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  color: #0f766e;
  font-size: 18rpx;
  font-weight: 800;
}

.note-title {
  color: #111827;
  font-size: 29rpx;
  font-weight: 700;
  line-height: 1.36;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.note-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
  margin-top: 16rpx;
  color: #7b8494;
  font-size: 23rpx;
}

.author {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex: 1;
  min-width: 0;
}

.author text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.avatar {
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  background: #e0f2fe;
  flex: none;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #0f766e;
  font-size: 19rpx;
  font-weight: 800;
}

.like {
  flex: none;
  color: #6b7280;
  font-size: 24rpx;
}
