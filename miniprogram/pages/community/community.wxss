.community {
  min-height: 100vh;
  padding: 16rpx 14rpx 170rpx;
  background: #fafafa;
}

.topbar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 14rpx;
}

.brand-title {
  flex: none;
  color: #111827;
  font-size: 42rpx;
  font-weight: 900;
}

.search-pill {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
  height: 66rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #f1f5f5;
  box-sizing: border-box;
}

.search-pill input {
  flex: 1;
  height: 66rpx;
  color: #111827;
  font-size: 27rpx;
}

.search-pill text {
  width: 40rpx;
  color: #94a3b8;
  font-size: 36rpx;
  text-align: right;
}

.channel-scroll {
  white-space: nowrap;
  margin: 0 -14rpx 18rpx;
}

.channel-row {
  display: flex;
  gap: 38rpx;
  padding: 0 14rpx;
}

.channel {
  position: relative;
  flex: none;
  padding: 12rpx 0 18rpx;
  color: #64748b;
  font-size: 30rpx;
  font-weight: 700;
}

.channel.active {
  color: #111827;
  font-weight: 900;
}

.channel.active::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: 4rpx;
  width: 34rpx;
  height: 7rpx;
  border-radius: 999rpx;
  background: #ef4056;
  transform: translateX(-50%);
}

.waterfall {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.waterfall-col {
  flex: 1;
  min-width: 0;
}

.note-card {
  margin-bottom: 12rpx;
  overflow: hidden;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 6rpx 22rpx rgba(15, 23, 42, 0.035);
}

.cover-wrap {
  position: relative;
  min-height: 200rpx;
  background: #f1f5f9;
}

.note-cover {
  width: 100%;
  display: block;
}

.video-badge {
  position: absolute;
  right: 12rpx;
  top: 12rpx;
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
  background: rgba(17, 24, 39, 0.66);
}

.video-badge::before {
  content: "";
  position: absolute;
  left: 18rpx;
  top: 13rpx;
  width: 0;
  height: 0;
  border-top: 10rpx solid transparent;
  border-bottom: 10rpx solid transparent;
  border-left: 15rpx solid #ffffff;
}

.cover-flags {
  position: absolute;
  left: 12rpx;
  right: 12rpx;
  bottom: 12rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.cover-flags text {
  height: 30rpx;
  line-height: 30rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: rgba(17, 24, 39, 0.66);
  color: #ffffff;
  font-size: 19rpx;
  font-weight: 800;
}

.poster-cover {
  position: relative;
  min-height: 278rpx;
  padding: 22rpx 20rpx 20rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.poster-mint {
  background: linear-gradient(150deg, #e7fbf4 0%, #c8f0f2 58%, #f7fffb 100%);
}

.poster-lemon {
  background: linear-gradient(150deg, #fff6c7 0%, #f8e0a1 55%, #fffaf0 100%);
}

.poster-rose {
  background: linear-gradient(150deg, #ffe7ec 0%, #ffc9d8 55%, #fff7f9 100%);
}

.poster-sky {
  background: linear-gradient(150deg, #e5f0ff 0%, #bdd8ff 58%, #f8fbff 100%);
}

.poster-paper {
  background: linear-gradient(150deg, #f4efe7 0%, #e7d9c8 55%, #fffaf3 100%);
}

.poster-orbit {
  position: absolute;
  border-radius: 50%;
  opacity: 0.46;
  pointer-events: none;
}

.poster-orbit.one {
  right: -36rpx;
  top: -30rpx;
  width: 122rpx;
  height: 122rpx;
  background: rgba(255, 255, 255, 0.72);
}

.poster-orbit.two {
  left: -24rpx;
  bottom: -26rpx;
  width: 92rpx;
  height: 92rpx;
  background: rgba(255, 255, 255, 0.58);
}

.poster-kicker {
  position: relative;
  display: inline-block;
  max-width: 100%;
  margin-bottom: 16rpx;
  padding: 7rpx 13rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #0f766e;
  font-size: 21rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.poster-title {
  position: relative;
  color: #172322;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.18;
  letter-spacing: 0;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.poster-title::after {
  content: "";
  display: block;
  width: 46rpx;
  height: 7rpx;
  margin-top: 16rpx;
  border-radius: 999rpx;
  background: rgba(239, 64, 86, 0.86);
}

.poster-teaser {
  position: relative;
  margin-top: 16rpx;
  color: rgba(17, 24, 39, 0.62);
  font-size: 23rpx;
  line-height: 1.45;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.note-body {
  padding: 14rpx 14rpx 16rpx;
}

.flag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 7rpx;
  margin-top: 10rpx;
}

.flag-row text {
  height: 27rpx;
  line-height: 27rpx;
  padding: 0 9rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  color: #0f766e;
  font-size: 18rpx;
  font-weight: 800;
}

.note-title {
  color: #111827;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.34;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.note-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
  margin-top: 14rpx;
  color: #64748b;
  font-size: 22rpx;
}

.author {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex: 1;
  min-width: 0;
}

.author text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.avatar {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #e0f2fe;
  flex: none;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #0f766e;
  font-size: 19rpx;
  font-weight: 800;
}

.like {
  flex: none;
  color: #64748b;
}
