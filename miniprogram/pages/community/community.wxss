.community {
  padding: 18rpx 18rpx 170rpx;
  background: #f7fbfb;
}

.topbar {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.brand-title {
  flex: none;
  color: #10201d;
  font-size: 38rpx;
  font-weight: 900;
}

.search-pill {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
  height: 62rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #eef6f6;
  box-sizing: border-box;
}

.search-pill input {
  flex: 1;
  height: 62rpx;
  color: #10201d;
  font-size: 25rpx;
}

.search-pill text {
  width: 40rpx;
  color: #94a3b8;
  font-size: 36rpx;
  text-align: right;
}

.channel-scroll {
  white-space: nowrap;
  margin: 0 -18rpx 20rpx;
}

.channel-row {
  display: flex;
  gap: 34rpx;
  padding: 0 18rpx;
}

.channel {
  position: relative;
  flex: none;
  padding: 10rpx 0 16rpx;
  color: #64748b;
  font-size: 29rpx;
  font-weight: 700;
}

.channel.active {
  color: #10201d;
  font-weight: 900;
}

.channel.active::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: 4rpx;
  width: 30rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: #078894;
  transform: translateX(-50%);
}

.waterfall {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.waterfall-col {
  flex: 1;
  min-width: 0;
}

.note-card {
  margin-bottom: 14rpx;
  overflow: hidden;
  border-radius: 12rpx;
  background: #ffffff;
}

.cover-wrap {
  position: relative;
  min-height: 188rpx;
  background: #eef6f6;
}

.note-cover {
  width: 100%;
  display: block;
}

.video-badge {
  position: absolute;
  left: 12rpx;
  bottom: 12rpx;
  width: 42rpx;
  height: 42rpx;
  line-height: 42rpx;
  text-align: center;
  border-radius: 50%;
  background: rgba(15, 23, 42, 0.68);
  color: #ffffff;
  font-size: 20rpx;
}

.text-cover {
  min-height: 196rpx;
  padding: 20rpx;
  box-sizing: border-box;
  background: #ffffff;
  color: #334155;
  font-size: 26rpx;
  line-height: 1.55;
  display: -webkit-box;
  -webkit-line-clamp: 5;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.text-type {
  display: inline-block;
  margin-bottom: 10rpx;
  padding: 5rpx 10rpx;
  border-radius: 999rpx;
  background: #e8f8f8;
  color: #078894;
  font-size: 21rpx;
  font-weight: 800;
}

.note-body {
  padding: 16rpx 16rpx 18rpx;
}

.note-title {
  color: #172322;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.38;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.note-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
  margin-top: 14rpx;
  color: #64748b;
  font-size: 22rpx;
}

.author {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex: 1;
  min-width: 0;
}

.author text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.avatar {
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: #dbeafe;
  flex: none;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #078894;
  font-size: 18rpx;
  font-weight: 800;
}

.like {
  flex: none;
  color: #64748b;
}
