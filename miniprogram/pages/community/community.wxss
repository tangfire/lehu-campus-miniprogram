.community {
  padding-bottom: 48rpx;
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 800;
}

.subtitle {
  margin-top: 6rpx;
  color: #64748b;
  font-size: 26rpx;
}

.publish-btn {
  width: 132rpx;
  height: 68rpx;
  line-height: 68rpx;
  border-radius: 10rpx;
  background: #0f766e;
  color: #ffffff;
  font-size: 28rpx;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx 18rpx;
  margin-bottom: 20rpx;
  background: #ffffff;
  border: 1rpx solid #e2e8f0;
  border-radius: 10rpx;
}

.search-row input {
  flex: 1;
  height: 54rpx;
  font-size: 27rpx;
}

.search-row button {
  margin: 0;
  width: 96rpx;
  height: 54rpx;
  line-height: 54rpx;
  border-radius: 8rpx;
  background: #f1f5f9;
  color: #475569;
  font-size: 24rpx;
}

.category-scroll {
  white-space: nowrap;
  margin: 0 -24rpx 14rpx;
}

.category-scroll.secondary {
  margin-bottom: 18rpx;
}

.category-row {
  display: flex;
  gap: 16rpx;
  padding: 0 24rpx;
}

.category-pill {
  flex: none;
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #475569;
  border: 1rpx solid #e2e8f0;
  font-size: 26rpx;
}

.category-pill.active {
  background: #0f766e;
  color: #ffffff;
  border-color: #0f766e;
}

.category-pill.channel {
  font-weight: 800;
}

.sort-row {
  display: flex;
  gap: 14rpx;
  margin-bottom: 20rpx;
}

.sort-item {
  padding: 12rpx 20rpx;
  color: #64748b;
  font-size: 26rpx;
}

.sort-item.active {
  color: #0f766e;
  font-weight: 700;
}

.waterfall {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}

.waterfall-col {
  flex: 1;
  min-width: 0;
}

.note-card {
  margin-bottom: 18rpx;
  overflow: hidden;
  border-radius: 8rpx;
  background: #ffffff;
  border: 1rpx solid #e2e8f0;
}

.cover-wrap {
  position: relative;
  min-height: 180rpx;
  background: #f1f5f9;
}

.note-cover {
  width: 100%;
  display: block;
}

.video-badge {
  position: absolute;
  left: 12rpx;
  bottom: 12rpx;
  width: 46rpx;
  height: 46rpx;
  line-height: 46rpx;
  text-align: center;
  border-radius: 50%;
  background: rgba(15, 23, 42, 0.72);
  color: #ffffff;
  font-size: 22rpx;
}

.type-badge {
  position: absolute;
  right: 12rpx;
  top: 12rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(15, 23, 42, 0.72);
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 800;
}

.text-cover {
  min-height: 180rpx;
  padding: 20rpx;
  box-sizing: border-box;
  background: #f8fafc;
  color: #334155;
  font-size: 26rpx;
  line-height: 1.55;
  display: -webkit-box;
  -webkit-line-clamp: 5;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.text-type {
  display: inline-block;
  margin-bottom: 10rpx;
  padding: 5rpx 10rpx;
  border-radius: 999rpx;
  background: #eef7f5;
  color: #0f766e;
  font-size: 21rpx;
  font-weight: 800;
}

.note-body {
  padding: 16rpx;
}

.note-title {
  color: #0f172a;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.35;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.note-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
  margin-top: 14rpx;
  color: #64748b;
  font-size: 22rpx;
}

.author {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex: 1;
  min-width: 0;
}

.author text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.avatar {
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: #dbeafe;
  flex: none;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #0f766e;
  font-size: 18rpx;
  font-weight: 800;
}
