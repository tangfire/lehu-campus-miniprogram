<view class="page community">
  <view class="topbar">
    <view>
      <view class="title">校园笔记</view>
      <view class="subtitle">同学们正在分享的校园瞬间</view>
    </view>
    <button class="publish-btn" bindtap="goPublish">发布</button>
  </view>

  <view class="search-row">
    <input value="{{keyword}}" bindinput="onSearch" confirm-type="search" bindconfirm="submitSearch" placeholder="搜索帖子、关键词" />
    <button wx:if="{{keyword}}" bindtap="clearSearch">清除</button>
  </view>

  <scroll-view class="category-scroll" scroll-x>
    <view class="category-row">
      <view
        wx:for="{{quickChannels}}"
        wx:key="label"
        class="category-pill channel {{activeChannel === item.label ? 'active' : ''}}"
        data-label="{{item.label}}"
        bindtap="changeChannel"
      >{{item.label}}</view>
    </view>
  </scroll-view>

  <scroll-view class="category-scroll secondary" scroll-x>
    <view class="category-row">
      <block wx:for="{{categories}}" wx:key="code">
        <view class="category-pill {{activeCategory === item.code ? 'active' : ''}}" data-code="{{item.code}}" bindtap="changeCategory">{{item.name}}</view>
      </block>
    </view>
  </scroll-view>

  <view class="sort-row">
    <view class="sort-item {{sort === 'new' ? 'active' : ''}}" data-sort="new" bindtap="changeSort">最新</view>
    <view class="sort-item {{sort === 'hot' ? 'active' : ''}}" data-sort="hot" bindtap="changeSort">热度</view>
  </view>

  <empty-state wx:if="{{!loading && posts.length === 0}}" title="还没有笔记" desc="发布第一条校园笔记，记录深汕校区的新鲜事。" />

  <view class="waterfall" wx:if="{{posts.length}}">
    <view class="waterfall-col">
      <block wx:for="{{leftPosts}}" wx:key="id">
        <view class="note-card" data-id="{{item.id}}" bindtap="openPost">
          <view wx:if="{{item.display_cover}}" class="cover-wrap">
            <image class="note-cover" src="{{item.display_cover}}" mode="widthFix" />
            <view wx:if="{{item.media_type === 'video'}}" class="video-badge">▶</view>
            <view class="type-badge">{{item.type_label}}</view>
          </view>
          <view wx:else class="text-cover">
            <view class="text-type">{{item.type_label}}</view>
            <view>{{item.content}}</view>
          </view>
          <view class="note-body">
            <view class="note-title">{{item.title}}</view>
            <view class="note-meta">
              <view class="author">
                <image wx:if="{{item.author && item.author.avatar}}" class="avatar" src="{{item.author.avatar}}" mode="aspectFill" />
                <view wx:else class="avatar avatar-placeholder">同</view>
                <text>{{item.display_author}}</text>
              </view>
              <text>{{item.like_count}}赞</text>
            </view>
          </view>
        </view>
      </block>
    </view>
    <view class="waterfall-col">
      <block wx:for="{{rightPosts}}" wx:key="id">
        <view class="note-card" data-id="{{item.id}}" bindtap="openPost">
          <view wx:if="{{item.display_cover}}" class="cover-wrap">
            <image class="note-cover" src="{{item.display_cover}}" mode="widthFix" />
            <view wx:if="{{item.media_type === 'video'}}" class="video-badge">▶</view>
            <view class="type-badge">{{item.type_label}}</view>
          </view>
          <view wx:else class="text-cover">
            <view class="text-type">{{item.type_label}}</view>
            <view>{{item.content}}</view>
          </view>
          <view class="note-body">
            <view class="note-title">{{item.title}}</view>
            <view class="note-meta">
              <view class="author">
                <image wx:if="{{item.author && item.author.avatar}}" class="avatar" src="{{item.author.avatar}}" mode="aspectFill" />
                <view wx:else class="avatar avatar-placeholder">同</view>
                <text>{{item.display_author}}</text>
              </view>
              <text>{{item.like_count}}赞</text>
            </view>
          </view>
        </view>
      </block>
    </view>
  </view>
</view>
