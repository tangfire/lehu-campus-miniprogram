<view class="page community">
  <view class="feed-sticky">
    <view class="topbar">
      <view class="brand-title">首页</view>
      <view class="search-pill">
        <view class="search-icon"></view>
        <input value="{{keyword}}" bindfocus="focusSearch" bindinput="onSearch" confirm-type="search" bindconfirm="submitSearch" placeholder="搜索深汕攻略、问答" />
        <text wx:if="{{keyword}}" bindtap="clearSearch">×</text>
      </view>
    </view>

    <view wx:if="{{showSearchPanel && recentSearches.length}}" class="search-panel">
      <view class="search-panel-head">
        <text>最近搜索</text>
        <text bindtap="clearRecentSearches">清空</text>
      </view>
      <view class="recent-row">
        <view wx:for="{{recentSearches}}" wx:key="*this" class="recent-chip" data-keyword="{{item}}" bindtap="useRecentSearch">{{item}}</view>
      </view>
    </view>

    <view wx:if="{{searchedKeyword}}" class="search-state">
      <text>搜索：{{searchedKeyword}}</text>
      <text bindtap="clearSearch">清除</text>
    </view>

    <scroll-view class="channel-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="channel-row">
        <view
          wx:for="{{quickChannels}}"
          wx:key="label"
          class="channel {{activeChannel === item.label ? 'active' : ''}}"
          data-label="{{item.label}}"
          bindtap="changeChannel"
        >{{item.label}}</view>
      </view>
    </scroll-view>
  </view>

  <view wx:if="{{!loading && posts.length === 0}}" class="community-empty">
    <empty-state title="{{emptyTitle}}" desc="{{emptyDesc}}" image="{{emptyImage}}" />
    <button wx:if="{{searchedKeyword}}" class="ask-btn" bindtap="createQuestionFromSearch">发个提问</button>
  </view>

  <view class="waterfall" wx:if="{{posts.length}}">
    <view class="waterfall-col">
      <block wx:for="{{leftPosts}}" wx:key="id">
        <view class="note-card" data-id="{{item.id}}" bindtap="openPost">
          <view wx:if="{{item.display_cover}}" class="cover-wrap">
            <image class="note-cover" src="{{item.display_cover}}" mode="widthFix" />
            <view wx:if="{{item.media_type === 'video'}}" class="video-badge"></view>
            <view wx:if="{{item.is_pinned || item.is_official || item.is_featured}}" class="cover-flags">
              <text wx:if="{{item.is_pinned}}">置顶</text>
              <text wx:if="{{item.is_official}}">官方</text>
              <text wx:if="{{item.is_featured}}">精选</text>
            </view>
          </view>
          <view wx:else class="poster-cover {{item.poster_class}}">
            <view class="poster-title">{{item.poster_title}}</view>
          </view>
          <view class="note-body">
            <view class="note-title">{{item.title}}</view>
            <view wx:if="{{item.is_pinned || item.is_official || item.is_featured}}" class="flag-row">
              <text wx:if="{{item.is_pinned}}">置顶</text>
              <text wx:if="{{item.is_official}}">官方</text>
              <text wx:if="{{item.is_featured}}">精选</text>
            </view>
            <view class="note-meta">
              <view class="author">
                <image wx:if="{{item.is_official}}" class="avatar official-avatar" src="/assets/brand/logo-ezai.png" mode="aspectFill" />
                <image wx:elif="{{item.author && item.author.avatar}}" class="avatar" src="{{item.author.avatar}}" mode="aspectFill" />
                <view wx:else class="avatar avatar-placeholder">{{item.avatar_text}}</view>
                <text>{{item.author_label}}</text>
              </view>
              <view class="like {{item.is_liked ? 'active' : ''}}" data-id="{{item.id}}" catchtap="toggleLike">
                <text>{{item.is_liked ? '♥' : '♡'}}</text>
                <text>{{item.display_count}}</text>
              </view>
            </view>
          </view>
        </view>
      </block>
    </view>
    <view class="waterfall-col">
      <block wx:for="{{rightPosts}}" wx:key="id">
        <view class="note-card" data-id="{{item.id}}" bindtap="openPost">
          <view wx:if="{{item.display_cover}}" class="cover-wrap">
            <image class="note-cover" src="{{item.display_cover}}" mode="widthFix" />
            <view wx:if="{{item.media_type === 'video'}}" class="video-badge"></view>
            <view wx:if="{{item.is_pinned || item.is_official || item.is_featured}}" class="cover-flags">
              <text wx:if="{{item.is_pinned}}">置顶</text>
              <text wx:if="{{item.is_official}}">官方</text>
              <text wx:if="{{item.is_featured}}">精选</text>
            </view>
          </view>
          <view wx:else class="poster-cover {{item.poster_class}}">
            <view class="poster-title">{{item.poster_title}}</view>
          </view>
          <view class="note-body">
            <view class="note-title">{{item.title}}</view>
            <view wx:if="{{item.is_pinned || item.is_official || item.is_featured}}" class="flag-row">
              <text wx:if="{{item.is_pinned}}">置顶</text>
              <text wx:if="{{item.is_official}}">官方</text>
              <text wx:if="{{item.is_featured}}">精选</text>
            </view>
            <view class="note-meta">
              <view class="author">
                <image wx:if="{{item.is_official}}" class="avatar official-avatar" src="/assets/brand/logo-ezai.png" mode="aspectFill" />
                <image wx:elif="{{item.author && item.author.avatar}}" class="avatar" src="{{item.author.avatar}}" mode="aspectFill" />
                <view wx:else class="avatar avatar-placeholder">{{item.avatar_text}}</view>
                <text>{{item.author_label}}</text>
              </view>
              <view class="like {{item.is_liked ? 'active' : ''}}" data-id="{{item.id}}" catchtap="toggleLike">
                <text>{{item.is_liked ? '♥' : '♡'}}</text>
                <text>{{item.display_count}}</text>
              </view>
            </view>
          </view>
        </view>
      </block>
    </view>
  </view>

</view>
