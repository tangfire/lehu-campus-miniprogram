.timetable {
  padding-bottom: 170rpx;
}

.login-panel,
.today,
.import-panel,
.week {
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.brand-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.brand-row {
  margin-bottom: 28rpx;
}

.brand-name {
  color: #10201d;
  font-size: 36rpx;
  font-weight: 900;
}

.login-panel .primary-btn {
  margin-top: 28rpx;
}

.top-line {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.eyebrow {
  color: #078894;
  font-size: 24rpx;
  font-weight: 700;
}

.title,
.panel-title {
  color: #10201d;
  font-size: 36rpx;
  font-weight: 900;
}

.title {
  margin-top: 8rpx;
}

.summary {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 25rpx;
}

.panel-title {
  margin-bottom: 22rpx;
}

.panel-title.compact {
  margin-bottom: 8rpx;
  font-size: 31rpx;
}

.top-actions {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 10rpx;
  width: 286rpx;
}

.mini-btn {
  width: 88rpx;
  height: 64rpx;
  margin: 0;
  padding: 0;
  border-radius: 10rpx;
  background: #e8f8f8;
  color: #078894;
  font-size: 26rpx;
  line-height: 64rpx;
}

.today-list {
  margin-top: 28rpx;
}

.today-course {
  display: flex;
  gap: 20rpx;
  padding: 22rpx 0;
  border-top: 1rpx solid #d9ecee;
}

.section {
  width: 150rpx;
  color: #078894;
  font-size: 26rpx;
  font-weight: 800;
}

.course-main,
.course-body {
  flex: 1;
  min-width: 0;
}

.course-name {
  color: #10201d;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.35;
}

.course-meta {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 25rpx;
  line-height: 1.4;
}

.empty-inline {
  margin-top: 28rpx;
  padding: 28rpx;
  border-radius: 10rpx;
  background: #f8fafc;
  color: #64748b;
  font-size: 27rpx;
  text-align: center;
}

.field {
  display: flex;
  align-items: center;
  min-height: 88rpx;
  border-bottom: 1rpx solid #d9ecee;
}

.field text {
  width: 120rpx;
  color: #334155;
  font-size: 28rpx;
  font-weight: 700;
}

.field input {
  flex: 1;
  color: #10201d;
  font-size: 28rpx;
}

.import-panel .primary-btn {
  margin-top: 28rpx;
}

.weekday-tabs {
  width: 100%;
  white-space: nowrap;
}

.weekday-row {
  display: flex;
  gap: 12rpx;
  min-width: max-content;
}

.weekday {
  width: 82rpx;
  height: 92rpx;
  border: 1rpx solid #dbe3ea;
  border-radius: 10rpx;
  background: #ffffff;
  color: #64748b;
  text-align: center;
  box-sizing: border-box;
  padding-top: 14rpx;
}

.weekday.active {
  border-color: #078894;
  background: #e8f8f8;
  color: #078894;
}

.weekday view {
  font-size: 28rpx;
  font-weight: 900;
}

.weekday text {
  display: block;
  margin-top: 4rpx;
  font-size: 22rpx;
}

.course-list {
  margin-top: 26rpx;
}

.course-card {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 0;
  border-top: 1rpx solid #d9ecee;
}

.course-time {
  width: 150rpx;
}

.course-time text {
  display: block;
  color: #078894;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.55;
}

.course-time text:last-child {
  color: #94a3b8;
  font-size: 22rpx;
  font-weight: 600;
}
