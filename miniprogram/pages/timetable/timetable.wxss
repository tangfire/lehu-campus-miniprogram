.timetable {
  padding-bottom: 170rpx;
  background: #f8f7f5;
}

.status-spacer {
  height: 0;
}

.login-panel,
.today,
.import-panel,
.week {
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.brand-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.brand-row {
  margin-bottom: 28rpx;
}

.brand-name {
  color: #18181b;
  font-size: 35rpx;
  font-weight: 900;
}

.login-panel .primary-btn {
  margin-top: 28rpx;
}

.demo-tip {
  margin: 0 0 20rpx;
  padding: 18rpx 22rpx;
  border-radius: 20rpx;
  background: #fff7f8;
  color: #9f1239;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.55;
}

.top-line {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.eyebrow {
  color: #ff4d5f;
  font-size: 23rpx;
  font-weight: 700;
}

.title,
.panel-title {
  color: #18181b;
  font-size: 35rpx;
  font-weight: 900;
}

.title {
  margin-top: 8rpx;
}

.summary {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 25rpx;
}

.panel-title {
  margin-bottom: 22rpx;
}

.import-note {
  margin: -8rpx 0 16rpx;
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.55;
}

.panel-title.compact {
  margin-bottom: 8rpx;
  font-size: 31rpx;
}

.top-actions {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 9rpx;
  width: 274rpx;
}

.mini-btn {
  width: 84rpx;
  height: 60rpx;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  background: #fff1f3;
  color: #ff4d5f;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 60rpx;
}

.today-list {
  margin-top: 28rpx;
}

.today-course {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid #f1ede8;
}

.section {
  width: 142rpx;
  color: #ff4d5f;
  font-size: 26rpx;
  font-weight: 800;
}

.course-main,
.course-body {
  flex: 1;
  min-width: 0;
}

.course-name {
  color: #18181b;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.35;
}

.demo-tag {
  display: inline-block;
  margin-left: 10rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: #fff1f3;
  color: #ff4d5f;
  font-size: 20rpx;
  font-weight: 900;
  vertical-align: 3rpx;
}

.course-meta {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 25rpx;
  line-height: 1.4;
}

.empty-inline {
  margin-top: 28rpx;
  padding: 28rpx;
  border-radius: 18rpx;
  background: #faf9f7;
  color: #64748b;
  font-size: 27rpx;
  text-align: center;
}

.field {
  display: flex;
  align-items: center;
  min-height: 88rpx;
  border-bottom: 1rpx solid #f1ede8;
}

.field text {
  width: 120rpx;
  color: #334155;
  font-size: 28rpx;
  font-weight: 700;
}

.field input {
  flex: 1;
  color: #18181b;
  font-size: 28rpx;
}

.import-panel .primary-btn {
  margin-top: 28rpx;
}

.weekday-tabs {
  width: 100%;
  white-space: nowrap;
}

.weekday-row {
  display: flex;
  gap: 10rpx;
  min-width: max-content;
}

.weekday {
  width: 82rpx;
  height: 90rpx;
  border: 1rpx solid #ece7e2;
  border-radius: 18rpx;
  background: #ffffff;
  color: #64748b;
  text-align: center;
  box-sizing: border-box;
  padding-top: 14rpx;
}

.weekday.active {
  border-color: #ff4d5f;
  background: #fff1f3;
  color: #ff4d5f;
}

.weekday view {
  font-size: 28rpx;
  font-weight: 900;
}

.weekday text {
  display: block;
  margin-top: 4rpx;
  font-size: 22rpx;
}

.course-list {
  margin-top: 24rpx;
}

.course-card {
  display: flex;
  gap: 20rpx;
  padding: 22rpx 0;
  border-top: 1rpx solid #f1ede8;
}

.course-time {
  width: 142rpx;
}

.course-time text {
  display: block;
  color: #ff4d5f;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.55;
}

.course-time text:last-child {
  color: #94a3b8;
  font-size: 22rpx;
  font-weight: 600;
}
