<view class="page timetable">
  <view wx:if="{{!token}}" class="panel login-panel">
    <view class="brand-row">
      <image class="brand-logo" src="/assets/logo-192.png" mode="aspectFit" />
      <view>
        <view class="brand-name">深汕校园e站</view>
        <view class="muted">深汕同学的课表与校园入口</view>
      </view>
    </view>
    <button class="primary-btn" bindtap="login">去登录</button>
  </view>

  <block wx:else>
    <view class="demo-tip">
      内测演示：真实教务导入需等学校确认开放，当前课表用于体验流程。
    </view>

    <view class="today panel">
      <view class="top-line">
        <view>
          <view class="eyebrow">{{term}}</view>
          <view class="title">今日课表</view>
          <view wx:if="{{shareSummary}}" class="summary">{{shareSummary}}</view>
        </view>
        <view class="top-actions">
          <button class="mini-btn" bindtap="toggleImportForm">{{showImportForm ? '收起' : '导入'}}</button>
          <button class="mini-btn" bindtap="shareToday">今日</button>
          <button class="mini-btn" bindtap="shareWeek">本周</button>
        </view>
      </view>

      <view wx:if="{{todayCourses.length}}" class="today-list">
        <view wx:for="{{todayCourses}}" wx:key="id" class="today-course">
          <view class="section">{{item.time_label}}</view>
          <view class="course-main">
            <view class="course-name">
              {{item.course_name}}
              <text wx:if="{{item.is_demo}}" class="demo-tag">演示数据</text>
            </view>
            <view class="course-meta">{{item.classroom || '教室待定'}} · {{item.teacher || '教师待定'}}</view>
          </view>
        </view>
      </view>
      <view wx:else class="empty-inline">{{courses.length ? '今天没有课程' : '还没有导入课表'}}</view>
    </view>

    <view wx:if="{{showImportForm}}" class="panel import-panel">
      <view class="panel-title">演示课表导入</view>
      <view class="import-note">输入任意符合格式的学号和密码即可生成演示课表；密码不会保存。</view>
      <view class="field">
        <text>学期</text>
        <input value="{{term}}" placeholder="例如 2026-2027-1" bindinput="onTermInput" />
      </view>
      <view class="field">
        <text>学号</text>
        <input value="{{studentNo}}" placeholder="请输入学号" bindinput="onStudentNoInput" />
      </view>
      <view class="field">
        <text>密码</text>
        <input value="{{password}}" password placeholder="仅用于本次导入" bindinput="onPasswordInput" />
      </view>
      <button class="primary-btn" loading="{{importing}}" bindtap="importTimetable">{{importButtonText}}</button>
    </view>

    <view class="week panel">
      <scroll-view class="weekday-tabs" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="weekday-row">
          <view
            wx:for="{{weekdayTabs}}"
            wx:key="value"
            class="weekday {{selectedWeekday === item.value ? 'active' : ''}}"
            data-weekday="{{item.value}}"
            bindtap="selectWeekday"
          >
            <view>{{item.short}}</view>
            <text>{{item.count || 0}}</text>
          </view>
        </view>
      </scroll-view>

      <view wx:if="{{selectedCourses.length}}" class="course-list">
        <view wx:for="{{selectedCourses}}" wx:key="id" class="course-card">
          <view class="course-time">
            <text>{{item.time_label}}</text>
            <text>{{item.week_label}}</text>
          </view>
          <view class="course-body">
            <view class="course-name">
              {{item.course_name}}
              <text wx:if="{{item.is_demo}}" class="demo-tag">演示数据</text>
            </view>
            <view class="course-meta">{{item.classroom || '教室待定'}}</view>
            <view class="course-meta">{{item.teacher || '教师待定'}}</view>
          </view>
        </view>
      </view>
      <empty-state wx:else title="这天没课" desc="切换其他日期查看课程安排。" />
    </view>
  </block>
</view>
