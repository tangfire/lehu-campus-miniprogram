.hero {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 32rpx;
}

.brand-logo {
  width: 96rpx;
  height: 96rpx;
  border-radius: 22rpx;
  flex: none;
}

.eyebrow {
  color: #078894;
  font-size: 24rpx;
  font-weight: 700;
}

.title {
  margin-top: 12rpx;
  font-size: 46rpx;
  font-weight: 900;
}

.desc {
  margin-top: 16rpx;
  color: #64748b;
  font-size: 28rpx;
  line-height: 1.7;
}
