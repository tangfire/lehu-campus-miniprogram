.freshman {
  padding-bottom: 170rpx;
}

.guide-hero {
  padding: 30rpx 30rpx 28rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #dbe7e5;
  border-radius: 16rpx;
  background: #ffffff;
}

.guide-eyebrow {
  color: #078894;
  font-size: 24rpx;
  font-weight: 800;
}

.guide-title {
  margin-top: 10rpx;
  color: #10201d;
  font-size: 42rpx;
  font-weight: 900;
}

.guide-desc {
  margin-top: 10rpx;
  color: #64748b;
  font-size: 26rpx;
  line-height: 1.6;
}

.guide-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.guide-card {
  min-height: 118rpx;
  padding: 20rpx;
  border: 1rpx solid #dbe7e5;
  border-radius: 14rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.guide-card-title {
  color: #10201d;
  font-size: 28rpx;
  font-weight: 900;
}

.guide-card-desc {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 22rpx;
  line-height: 1.35;
}

.category-scroll {
  white-space: nowrap;
  margin: 0 -24rpx 18rpx;
}

.category-row {
  display: flex;
  gap: 14rpx;
  padding: 0 24rpx;
}

.category-pill {
  flex: none;
  padding: 15rpx 24rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #475569;
  border: 1rpx solid #d9ecee;
  font-size: 26rpx;
}

.category-pill.active {
  background: #078894;
  color: #ffffff;
  border-color: #078894;
}

.favorite-filter {
  margin-left: 4rpx;
}

.empty {
  padding: 40rpx 28rpx;
  margin-bottom: 18rpx;
  text-align: center;
}

.empty-title {
  color: #10201d;
  font-size: 30rpx;
  font-weight: 900;
}

.empty-desc {
  margin-top: 10rpx;
  color: #64748b;
  font-size: 25rpx;
  line-height: 1.5;
}

.tool {
  margin-bottom: 18rpx;
  overflow: hidden;
}

.tool-head {
  display: flex;
  gap: 18rpx;
  padding: 24rpx;
}

.tool-main {
  flex: 1;
  min-width: 0;
}

.tool-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.badge,
.status {
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.badge {
  background: #e8f8f8;
  color: #078894;
  font-weight: 800;
}

.status {
  background: #f8fafc;
  color: #64748b;
}

.progress {
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  background: #ecfdf5;
  color: #059669;
  font-size: 22rpx;
  font-weight: 800;
}

.tool-title {
  color: #10201d;
  font-size: 31rpx;
  font-weight: 900;
}

.tool-summary {
  margin-top: 10rpx;
  color: #64748b;
  font-size: 26rpx;
  line-height: 1.55;
}

.favorite {
  width: 104rpx;
  height: 58rpx;
  margin: 0;
  padding: 0;
  border-radius: 8rpx;
  background: #f1f5f9;
  color: #64748b;
  font-size: 24rpx;
  line-height: 58rpx;
}

.favorite.active {
  background: #078894;
  color: #ffffff;
}

.tool-detail {
  padding: 0 24rpx 24rpx;
  border-top: 1rpx solid #d9ecee;
}

.body {
  padding-top: 22rpx;
  color: #334155;
  font-size: 28rpx;
  line-height: 1.7;
}

.source {
  margin-top: 14rpx;
  padding: 14rpx 16rpx;
  border-radius: 10rpx;
  background: #f8fafc;
  color: #64748b;
  font-size: 23rpx;
  line-height: 1.5;
}

.checklist {
  margin-top: 22rpx;
  border: 1rpx solid #dbe7e5;
  border-radius: 12rpx;
  overflow: hidden;
}

.check-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 18rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #edf2f7;
}

.check-row:last-child {
  border-bottom: 0;
}

.check-row.checked .check-text {
  color: #94a3b8;
  text-decoration: line-through;
}

.check-box {
  flex: none;
  width: 34rpx;
  height: 34rpx;
  margin-top: 2rpx;
  border: 2rpx solid #cbd5e1;
  border-radius: 8rpx;
  color: #ffffff;
  background: #ffffff;
  font-size: 24rpx;
  line-height: 34rpx;
  text-align: center;
  box-sizing: border-box;
}

.check-row.checked .check-box {
  border-color: #078894;
  background: #078894;
}

.check-text {
  flex: 1;
  min-width: 0;
  color: #334155;
  font-size: 27rpx;
  line-height: 1.45;
}

.tips {
  margin-top: 18rpx;
}

.tip-row {
  position: relative;
  padding: 14rpx 16rpx 14rpx 38rpx;
  margin-bottom: 10rpx;
  border-radius: 10rpx;
  background: #fff7ed;
  color: #9a3412;
  font-size: 25rpx;
  line-height: 1.45;
}

.tip-row::before {
  content: '';
  position: absolute;
  left: 18rpx;
  top: 26rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: #f97316;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.tag-row text {
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  background: #f8fafc;
  color: #64748b;
  font-size: 22rpx;
}

.action-row {
  display: flex;
  gap: 14rpx;
  margin-top: 20rpx;
}

.action-row button,
.link-row button {
  margin: 0;
  height: 58rpx;
  line-height: 58rpx;
  border-radius: 8rpx;
  background: #e8f8f8;
  color: #078894;
  font-size: 24rpx;
}

.action-row button {
  flex: 1;
}

.links {
  margin-top: 18rpx;
  border-top: 1rpx solid #d9ecee;
}

.link-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #d9ecee;
}

.link-row text {
  color: #334155;
  font-size: 27rpx;
}

.link-row button {
  width: 96rpx;
}

.updated {
  margin-top: 18rpx;
  color: #94a3b8;
  font-size: 23rpx;
}
