.mine {
  padding: 22rpx 22rpx 170rpx;
  background: #f7fbfb;
}

.profile-card {
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 18rpx;
  background: #ffffff;
}

.profile-top {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.avatar {
  width: 116rpx;
  height: 116rpx;
  border-radius: 50%;
  background: #dbeafe;
  flex: none;
}

.logo-avatar {
  border-radius: 26rpx;
  background: #ffffff;
}

.profile-main {
  flex: 1;
  min-width: 0;
}

.avatar-wrap {
  position: relative;
  flex: none;
  width: 116rpx;
  height: 116rpx;
}

.avatar-edit {
  position: absolute;
  right: -4rpx;
  bottom: -2rpx;
  width: 42rpx;
  height: 42rpx;
  line-height: 42rpx;
  border: 4rpx solid #ffffff;
  border-radius: 50%;
  background: #078894;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 900;
  text-align: center;
  box-sizing: border-box;
}

.name {
  color: #10201d;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.25;
}

.bio {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 26rpx;
  line-height: 1.45;
}

.login-btn {
  height: 78rpx;
  margin: 28rpx 0 0;
  border-radius: 999rpx;
  background: #078894;
  color: #ffffff;
  font-size: 28rpx;
  line-height: 78rpx;
}

.profile-status {
  display: flex;
  gap: 12rpx;
  margin-top: 24rpx;
}

.profile-status text {
  padding: 9rpx 14rpx;
  border-radius: 999rpx;
  background: #e8f8f8;
  color: #078894;
  font-size: 23rpx;
  font-weight: 700;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
  margin-bottom: 20rpx;
}

.quick-card {
  min-height: 124rpx;
  padding: 22rpx 20rpx;
  border-radius: 16rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.quick-title {
  color: #10201d;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1.25;
}

.quick-desc {
  margin-top: 10rpx;
  color: #64748b;
  font-size: 21rpx;
  line-height: 1.35;
}

.info {
  padding: 4rpx 24rpx;
  margin-bottom: 20rpx;
}

.info-head {
  padding: 22rpx 0 8rpx;
  color: #10201d;
  font-size: 29rpx;
  font-weight: 900;
}

.menu {
  padding: 0 24rpx;
}

.menu-row,
.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 24rpx;
  padding: 26rpx 0;
  border-bottom: 1rpx solid #d9ecee;
  font-size: 28rpx;
}

.menu-row:last-child,
.row:last-child {
  border-bottom: 0;
}

.menu-row text:first-child,
.row text:first-child {
  color: #10201d;
  font-weight: 700;
}

.menu-row text:last-child {
  color: #94a3b8;
  font-size: 36rpx;
}

.row text:last-child {
  color: #64748b;
  text-align: right;
}
