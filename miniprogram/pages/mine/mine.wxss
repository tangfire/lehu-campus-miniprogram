.mine {
  padding: 22rpx 26rpx 170rpx;
  background: #fbfbfa;
}

.status-spacer {
  height: 0;
}

.mine-header {
  display: flex;
  align-items: flex-start;
  margin: 30rpx 10rpx 34rpx;
}

.page-title {
  color: #172033;
  font-size: 48rpx;
  font-weight: 900;
  line-height: 1.05;
}

.title-wave {
  width: 64rpx;
  height: 10rpx;
  margin-top: 14rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #ff5d6f, #ff9aa7);
}

.profile-card {
  position: relative;
  min-height: 344rpx;
  padding: 44rpx 36rpx 34rpx;
  margin-bottom: 28rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.05);
  border-radius: 30rpx;
  background: linear-gradient(135deg, #fffafa 0%, #ffffff 48%, #effaff 100%);
  box-shadow: 0 18rpx 42rpx rgba(255, 77, 95, 0.08);
  box-sizing: border-box;
  overflow: hidden;
}

.profile-ip {
  position: absolute;
  right: -40rpx;
  bottom: -18rpx;
  width: 230rpx;
  height: 230rpx;
  opacity: 0.16;
  pointer-events: none;
}

.profile-top {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  gap: 26rpx;
}

.avatar {
  width: 124rpx;
  height: 124rpx;
  border-radius: 50%;
  background: #dbeafe;
  flex: none;
}

.logo-avatar {
  border-radius: 50%;
  background: #ffffff;
}

.profile-main {
  flex: 1;
  min-width: 0;
}

.avatar-wrap {
  position: relative;
  flex: none;
  width: 124rpx;
  height: 124rpx;
  border-radius: 50%;
  background: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.08);
}

.name {
  color: #172033;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1.25;
}

.bio {
  margin-top: 12rpx;
  color: #64748b;
  font-size: 28rpx;
  line-height: 1.45;
}

.login-btn {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  width: 332rpx;
  height: 78rpx;
  margin: 38rpx 0 0 8rpx;
  padding: 0;
  border-radius: 999rpx;
  background: #1fce66;
  color: #ffffff;
  font-size: 29rpx;
  font-weight: 900;
  line-height: 78rpx;
  box-shadow: 0 14rpx 28rpx rgba(31, 206, 102, 0.22);
}

.login-btn::after {
  border: 0;
}

.login-btn[loading] {
  opacity: 0.78;
}

.wechat-icon {
  position: relative;
  width: 44rpx;
  height: 38rpx;
  flex: none;
}

.wechat-bubble {
  position: absolute;
  border-radius: 50%;
  background: #ffffff;
}

.wechat-bubble::before,
.wechat-bubble::after {
  content: "";
  position: absolute;
  top: 14rpx;
  width: 5rpx;
  height: 5rpx;
  border-radius: 50%;
  background: #1fce66;
}

.wechat-bubble.main {
  left: 0;
  top: 2rpx;
  width: 31rpx;
  height: 25rpx;
}

.wechat-bubble.main::before {
  left: 9rpx;
}

.wechat-bubble.main::after {
  right: 9rpx;
}

.wechat-bubble.sub {
  right: 0;
  bottom: 0;
  width: 26rpx;
  height: 21rpx;
  opacity: 0.9;
}

.wechat-bubble.sub::before {
  left: 8rpx;
  top: 11rpx;
}

.wechat-bubble.sub::after {
  right: 7rpx;
  top: 11rpx;
}

.profile-status {
  position: relative;
  z-index: 2;
  display: flex;
  gap: 12rpx;
  margin-top: 24rpx;
}

.profile-status text {
  padding: 9rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #20a755;
  font-size: 23rpx;
  font-weight: 700;
}

.message-card {
  position: relative;
  display: flex;
  align-items: center;
  gap: 22rpx;
  min-height: 124rpx;
  padding: 24rpx 72rpx 24rpx 24rpx;
  margin-bottom: 24rpx;
  border-radius: 26rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 34rpx rgba(15, 23, 42, 0.06);
  box-sizing: border-box;
}

.message-icon {
  width: 68rpx;
  height: 68rpx;
  border-radius: 20rpx;
  background: #fff7f8;
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 68rpx;
  text-align: center;
  flex: none;
}

.message-icon.brand {
  overflow: hidden;
  padding: 4rpx;
  box-sizing: border-box;
  box-shadow: 0 6rpx 16rpx rgba(255, 77, 95, 0.1);
}

.message-main {
  flex: 1;
  min-width: 0;
}

.message-title {
  color: #111827;
  font-size: 31rpx;
  font-weight: 900;
  line-height: 1.25;
}

.message-desc {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 24rpx;
}

.message-badge {
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 9rpx;
  border-radius: 999rpx;
  background: #ff4d5f;
  color: #ffffff;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 34rpx;
  text-align: center;
  box-sizing: border-box;
}

.message-arrow {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  color: #cbd5e1;
  font-size: 44rpx;
  line-height: 1;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
  margin-bottom: 30rpx;
}

.quick-card {
  position: relative;
  min-height: 204rpx;
  padding: 26rpx 20rpx 20rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 34rpx rgba(15, 23, 42, 0.06);
  box-sizing: border-box;
  overflow: hidden;
}

.quick-icon {
  width: 62rpx;
  height: 62rpx;
  margin-bottom: 26rpx;
  border-radius: 20rpx;
}

.plane-icon {
  position: relative;
  background: linear-gradient(135deg, #d7f8eb, #b9f2df);
}

.plane-icon::after {
  content: "";
  position: absolute;
  left: 15rpx;
  top: 19rpx;
  width: 0;
  height: 0;
  border-left: 34rpx solid #17bf82;
  border-top: 12rpx solid transparent;
  border-bottom: 10rpx solid transparent;
  transform: rotate(-14deg);
}

.star-icon {
  background: linear-gradient(135deg, #fff2d7, #ffe4b0);
  color: #f59e0b;
  font-size: 39rpx;
  line-height: 62rpx;
  text-align: center;
}

.comment-icon {
  position: relative;
  background: linear-gradient(135deg, #ffe1e7, #ffc7d2);
}

.comment-icon::before {
  content: "";
  position: absolute;
  left: 14rpx;
  top: 15rpx;
  width: 34rpx;
  height: 28rpx;
  border-radius: 50% 50% 50% 10rpx;
  background: #ff5d72;
}

.quick-title {
  color: #111827;
  font-size: 29rpx;
  font-weight: 900;
  line-height: 1.25;
}

.quick-desc {
  margin-top: 10rpx;
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.35;
}

.quick-arrow {
  position: absolute;
  right: 22rpx;
  bottom: 22rpx;
  width: 38rpx;
  height: 38rpx;
  line-height: 35rpx;
  border-radius: 50%;
  background: #e9fff5;
  color: #16c784;
  font-size: 34rpx;
  text-align: center;
}

.collect-card .quick-arrow {
  background: #fff7df;
  color: #f59e0b;
}

.comment-card .quick-arrow {
  background: #fff0f3;
  color: #ff5d72;
}

.draft-card .quick-arrow {
  background: #eef2ff;
  color: #6366f1;
}

.draft-card.has-draft {
  border: 1rpx solid rgba(255, 77, 95, 0.18);
}

.draft-icon {
  position: relative;
  background: linear-gradient(135deg, #e8edff, #dce5ff);
}

.draft-icon::before {
  content: "";
  position: absolute;
  left: 15rpx;
  top: 12rpx;
  width: 30rpx;
  height: 38rpx;
  border-radius: 6rpx;
  background: #6366f1;
}

.draft-icon::after {
  content: "";
  position: absolute;
  left: 22rpx;
  top: 23rpx;
  width: 18rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 0 #ffffff;
}

.info {
  padding: 4rpx 24rpx;
  margin-top: 26rpx;
  margin-bottom: 18rpx;
}

.info-head {
  padding: 22rpx 0 8rpx;
  color: #18181b;
  font-size: 29rpx;
  font-weight: 900;
}

.menu {
  padding: 0 30rpx;
  border-radius: 26rpx;
}

.menu-row,
.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx 0;
  border-bottom: 1rpx solid #f0f1f3;
  font-size: 29rpx;
}

.menu-row:last-child,
.row:last-child {
  border-bottom: 0;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 26rpx;
  min-width: 0;
}

.menu-icon {
  position: relative;
  width: 42rpx;
  height: 42rpx;
  border-radius: 13rpx;
  flex: none;
}

.profile-icon {
  background: linear-gradient(135deg, #6a8cff, #5273f5);
}

.profile-icon::after {
  content: "";
  position: absolute;
  left: 13rpx;
  top: 10rpx;
  width: 18rpx;
  height: 22rpx;
  border-radius: 5rpx;
  background: rgba(255, 255, 255, 0.9);
}

.about-icon {
  background: linear-gradient(135deg, #35d5c8, #19b9b6);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 42rpx;
  text-align: center;
}

.feedback-icon {
  background: linear-gradient(135deg, #ff9aa7, #ff4d5f);
}

.feedback-icon::before {
  content: "";
  position: absolute;
  left: 10rpx;
  top: 11rpx;
  width: 22rpx;
  height: 16rpx;
  border: 4rpx solid #ffffff;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.feedback-icon::after {
  content: "";
  position: absolute;
  left: 16rpx;
  bottom: 8rpx;
  width: 10rpx;
  height: 10rpx;
  background: #ffffff;
  clip-path: polygon(0 0, 100% 0, 0 100%);
}

.rules-icon {
  background: linear-gradient(135deg, #8b5cf6, #6366f1);
}

.rules-icon::before {
  content: "";
  position: absolute;
  left: 11rpx;
  top: 10rpx;
  width: 20rpx;
  height: 24rpx;
  border: 4rpx solid #ffffff;
  border-radius: 5rpx;
  box-sizing: border-box;
}

.rules-icon::after {
  content: "";
  position: absolute;
  right: 8rpx;
  bottom: 9rpx;
  width: 14rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: #ffffff;
  transform: rotate(-35deg);
}

.logout-icon {
  background: linear-gradient(135deg, #ffe1e7, #ff8ca0);
}

.logout-icon::after {
  content: "";
  position: absolute;
  left: 13rpx;
  top: 12rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  border: 4rpx solid #ffffff;
  border-top-color: transparent;
  box-sizing: border-box;
}

.menu-left text,
.row text:first-child {
  color: #111827;
  font-weight: 900;
}

.menu-arrow {
  color: #b8bec8;
  font-size: 42rpx;
  font-weight: 300;
}

.row text:last-child {
  color: #64748b;
  text-align: right;
}

.compact-links {
  justify-content: flex-start;
  gap: 18rpx;
  padding: 24rpx 0;
}

.policy-link {
  padding: 11rpx 18rpx;
  border-radius: 999rpx;
  background: #f8fafc;
  color: #64748b;
  font-size: 24rpx;
  font-weight: 800;
}
