.mine {
  padding: 24rpx 22rpx 170rpx;
  background: #f8f7f5;
}

.profile-card {
  padding: 32rpx;
  margin-bottom: 18rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 30rpx rgba(15, 23, 42, 0.04);
}

.profile-top {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: #dbeafe;
  flex: none;
}

.logo-avatar {
  border-radius: 26rpx;
  background: #ffffff;
}

.profile-main {
  flex: 1;
  min-width: 0;
}

.avatar-wrap {
  position: relative;
  flex: none;
  width: 112rpx;
  height: 112rpx;
}

.avatar-edit {
  position: absolute;
  right: -4rpx;
  bottom: -2rpx;
  width: 42rpx;
  height: 42rpx;
  line-height: 42rpx;
  border: 4rpx solid #ffffff;
  border-radius: 50%;
  background: #ff4d5f;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 900;
  text-align: center;
  box-sizing: border-box;
}

.name {
  color: #18181b;
  font-size: 37rpx;
  font-weight: 900;
  line-height: 1.25;
}

.bio {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 26rpx;
  line-height: 1.45;
}

.login-btn {
  height: 78rpx;
  margin: 28rpx 0 0;
  border-radius: 999rpx;
  background: #ff4d5f;
  color: #ffffff;
  font-size: 28rpx;
  line-height: 78rpx;
  box-shadow: 0 10rpx 22rpx rgba(255, 77, 95, 0.18);
}

.profile-status {
  display: flex;
  gap: 12rpx;
  margin-top: 24rpx;
}

.profile-status text {
  padding: 9rpx 14rpx;
  border-radius: 999rpx;
  background: #fff1f3;
  color: #ff4d5f;
  font-size: 23rpx;
  font-weight: 700;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.quick-card {
  min-height: 132rpx;
  padding: 24rpx 16rpx 20rpx;
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.035);
  box-sizing: border-box;
}

.quick-title {
  color: #18181b;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 1.25;
}

.quick-desc {
  margin-top: 12rpx;
  color: #64748b;
  font-size: 21rpx;
  line-height: 1.35;
}

.info {
  padding: 4rpx 24rpx;
  margin-bottom: 18rpx;
}

.info-head {
  padding: 22rpx 0 8rpx;
  color: #18181b;
  font-size: 29rpx;
  font-weight: 900;
}

.menu {
  padding: 0 24rpx;
  border-radius: 24rpx;
}

.menu-row,
.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f1ede8;
  font-size: 28rpx;
}

.menu-row:last-child,
.row:last-child {
  border-bottom: 0;
}

.menu-row text:first-child,
.row text:first-child {
  color: #18181b;
  font-weight: 700;
}

.menu-row text:last-child {
  color: #c4c9d1;
  font-size: 30rpx;
}

.row text:last-child {
  color: #64748b;
  text-align: right;
}
