<view class="page mine">
  <view class="status-spacer" style="height: {{statusBarHeight}}px"></view>
  <view class="mine-header">
    <view>
      <view class="page-title">我的</view>
      <view class="title-wave"></view>
    </view>
  </view>

  <view class="profile-card">
    <image class="profile-ip" src="/assets/brand/stickers/welcome.png" mode="aspectFit" />
    <view class="profile-top">
      <view class="avatar-wrap" bindtap="changeAvatar">
        <image wx:if="{{user && user.avatar}}" class="avatar" src="{{user.avatar}}" mode="aspectFill" />
        <image wx:else class="avatar logo-avatar" src="/assets/brand/logo-ezai.png" mode="aspectFill" />
      </view>
      <view class="profile-main">
        <view class="name">{{user ? (user.nickname || user.name || '深汕同学') : '深汕校园e站'}}</view>
        <view class="bio">{{profile ? profile.school_name : '深汕校园生活入口'}}</view>
      </view>
    </view>
    <button wx:if="{{!token}}" class="login-btn" loading="{{loggingIn}}" bindtap="login">
      <view class="wechat-icon">
        <view class="wechat-bubble main"></view>
        <view class="wechat-bubble sub"></view>
      </view>
      <text>微信登录</text>
    </button>
    <view wx:else class="profile-status">
      <text>{{profile && profile.auth_status === 1 ? '已认证' : '待校园认证'}}</text>
      <text>{{profile && profile.class_name ? profile.class_name : '完善资料后更好用'}}</text>
    </view>
  </view>

  <view class="message-card" bindtap="goNotifications">
    <image class="message-icon brand" src="/assets/brand/stickers/notice.png" mode="aspectFit" />
    <view class="message-main">
      <view class="message-title">消息中心</view>
      <view class="message-desc">{{unreadCount ? unreadCount + ' 条未读消息' : '回复、赞藏和系统通知'}}</view>
    </view>
    <view wx:if="{{unreadCount}}" class="message-badge">{{unreadCount > 99 ? '99+' : unreadCount}}</view>
    <view class="message-arrow">›</view>
  </view>

  <view class="quick-grid">
    <view class="quick-card publish-card" bindtap="goMyPosts">
      <view class="quick-icon plane-icon"></view>
      <view class="quick-title">我的发布</view>
      <view class="quick-desc">笔记和动态</view>
      <view class="quick-arrow">›</view>
    </view>
    <view class="quick-card collect-card" bindtap="goMyCollections">
      <view class="quick-icon star-icon">★</view>
      <view class="quick-title">我的收藏</view>
      <view class="quick-desc">攻略和问答</view>
      <view class="quick-arrow">›</view>
    </view>
    <view class="quick-card comment-card" bindtap="goMyComments">
      <view class="quick-icon comment-icon"></view>
      <view class="quick-title">我的评论</view>
      <view class="quick-desc">看过的讨论</view>
      <view class="quick-arrow">›</view>
    </view>
    <view class="quick-card draft-card {{hasDraft ? 'has-draft' : ''}}" bindtap="goDrafts">
      <view class="quick-icon draft-icon"></view>
      <view class="quick-title">草稿箱</view>
      <view class="quick-desc">{{draftDesc}}</view>
      <view class="quick-arrow">›</view>
    </view>
  </view>

  <view class="panel menu">
    <view class="menu-row" bindtap="editProfile">
      <view class="menu-left">
        <view class="menu-icon profile-icon"></view>
        <text>编辑校园资料</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-row" bindtap="goAboutUs">
      <view class="menu-left">
        <view class="menu-icon about-icon">i</view>
        <text>关于我们</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-row" bindtap="goFeedback">
      <view class="menu-left">
        <view class="menu-icon feedback-icon"></view>
        <text>意见反馈 / 联系我们</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-row" data-type="rules" bindtap="goPolicy">
      <view class="menu-left">
        <view class="menu-icon rules-icon"></view>
        <text>社区规范</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-row compact-links">
      <view class="policy-link" data-type="terms" bindtap="goPolicy">用户协议</view>
      <view class="policy-link" data-type="privacy" bindtap="goPolicy">隐私政策</view>
    </view>
    <view class="menu-row" wx:if="{{token}}" bindtap="logout">
      <view class="menu-left">
        <view class="menu-icon logout-icon"></view>
        <text>退出登录</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="panel info" wx:if="{{profile && (profile.dorm_building || profile.class_name)}}">
    <view class="info-head">校园资料</view>
    <view class="row">
      <text>宿舍</text>
      <text>{{profile.dorm_building || '未填写'}} {{profile.room_no || ''}}</text>
    </view>
    <view class="row">
      <text>班级</text>
      <text>{{profile.class_name || '未填写'}}</text>
    </view>
  </view>
</view>
