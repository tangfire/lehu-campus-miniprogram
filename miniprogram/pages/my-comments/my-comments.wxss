.my-comments {
  padding: 22rpx;
  background: #f8f7f5;
}

.comment-card {
  padding: 24rpx;
  margin-bottom: 16rpx;
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.035);
}

.comment-content {
  color: #18181b;
  font-size: 29rpx;
  line-height: 1.65;
}

.comment-time {
  margin-top: 10rpx;
  color: #94a3b8;
  font-size: 23rpx;
}

.post-box {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 18rpx;
  padding: 16rpx;
  border-radius: 18rpx;
  background: #faf9f7;
}

.post-cover {
  width: 92rpx;
  height: 92rpx;
  border-radius: 14rpx;
  background: #f5f1ee;
  flex: none;
}

.text-cover {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ff4d5f;
  font-size: 32rpx;
  font-weight: 900;
}

.post-main {
  flex: 1;
  min-width: 0;
}

.post-title {
  color: #18181b;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.post-meta {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 22rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
