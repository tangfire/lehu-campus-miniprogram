.my-comments {
  padding: 22rpx;
  background: #f7fbfb;
}

.comment-card {
  padding: 24rpx;
  margin-bottom: 18rpx;
  border-radius: 16rpx;
  background: #ffffff;
}

.comment-content {
  color: #10201d;
  font-size: 29rpx;
  line-height: 1.65;
}

.comment-time {
  margin-top: 10rpx;
  color: #94a3b8;
  font-size: 23rpx;
}

.post-box {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 18rpx;
  padding: 16rpx;
  border-radius: 12rpx;
  background: #f7fbfb;
}

.post-cover {
  width: 92rpx;
  height: 92rpx;
  border-radius: 10rpx;
  background: #eef6f6;
  flex: none;
}

.text-cover {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #078894;
  font-size: 32rpx;
  font-weight: 900;
}

.post-main {
  flex: 1;
  min-width: 0;
}

.post-title {
  color: #10201d;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.post-meta {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 22rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
