.publish {
  padding: 20rpx 20rpx 56rpx;
  background: #f7fbfb;
}

.composer-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 20rpx;
}

.composer-title {
  color: #10201d;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.2;
}

.composer-subtitle {
  margin-top: 6rpx;
  color: #64748b;
  font-size: 24rpx;
}

.publish-btn {
  flex: none;
  width: 128rpx;
  height: 64rpx;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  background: #078894;
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 64rpx;
}

.starter,
.media-panel,
.form {
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 0;
  border-radius: 18rpx;
  background: #ffffff;
}

.starter-title,
.media-panel-head,
.section-title {
  color: #10201d;
  font-size: 28rpx;
  font-weight: 900;
}

.starter-title {
  margin-bottom: 20rpx;
}

.starter-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.starter-item {
  height: 154rpx;
  border-radius: 16rpx;
  background: #f8fafc;
  color: #334155;
  font-size: 24rpx;
  font-weight: 800;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
}

.starter-icon {
  width: 54rpx;
  height: 54rpx;
  position: relative;
  color: #078894;
}

.image-icon {
  border: 4rpx solid currentColor;
  border-radius: 10rpx;
}

.image-icon::before {
  content: "";
  position: absolute;
  left: 10rpx;
  bottom: 10rpx;
  width: 28rpx;
  height: 20rpx;
  background: currentColor;
  clip-path: polygon(0 100%, 42% 36%, 62% 62%, 78% 42%, 100% 100%);
}

.camera-icon {
  border: 4rpx solid currentColor;
  border-radius: 12rpx;
}

.camera-icon::before {
  content: "";
  position: absolute;
  left: 15rpx;
  top: 15rpx;
  width: 16rpx;
  height: 16rpx;
  border: 4rpx solid currentColor;
  border-radius: 50%;
}

.text-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  background: #e8f8f8;
  font-size: 24rpx;
  font-weight: 900;
}

.media-panel-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
}

.media-panel-head text:last-child {
  color: #94a3b8;
  font-size: 23rpx;
  font-weight: 700;
}

.image-picker {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.image-wrap {
  position: relative;
  width: 100%;
  height: 200rpx;
  overflow: hidden;
  border-radius: 12rpx;
  background: #f1f5f9;
}

.picked-image,
.add-image {
  width: 100%;
  height: 200rpx;
}

.picked-image {
  display: block;
}

.image-actions {
  position: absolute;
  left: 8rpx;
  right: 8rpx;
  bottom: 8rpx;
  display: flex;
  gap: 8rpx;
}

.image-actions view {
  flex: 1;
  height: 42rpx;
  line-height: 42rpx;
  border-radius: 999rpx;
  background: rgba(15, 23, 42, 0.68);
  color: #ffffff;
  font-size: 21rpx;
  text-align: center;
}

.add-image {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx dashed #94a3b8;
  border-radius: 12rpx;
  background: #f8fafc;
  color: #64748b;
  font-size: 52rpx;
  box-sizing: border-box;
}

.video-picker {
  padding-top: 2rpx;
}

.video-wrap {
  position: relative;
}

.picked-video,
.add-video {
  width: 100%;
  height: 390rpx;
  border-radius: 14rpx;
  background: #0f172a;
  overflow: hidden;
}

.add-video {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  color: #d9ecee;
  font-size: 28rpx;
}

.add-video text {
  color: #94a3b8;
  font-size: 23rpx;
}

.add-video-icon {
  width: 72rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.16);
  font-size: 32rpx;
}

.remove {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 40rpx;
  height: 40rpx;
  line-height: 38rpx;
  text-align: center;
  border-radius: 50%;
  background: rgba(15, 23, 42, 0.72);
  color: #ffffff;
  font-size: 28rpx;
}

.remove.small {
  width: 34rpx;
  height: 34rpx;
  line-height: 32rpx;
  font-size: 24rpx;
}

.video-meta {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
  margin-top: 12rpx;
}

.video-meta text {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #eef6f6;
  color: #64748b;
  font-size: 23rpx;
}

.cover-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 18rpx;
}

.cover-label {
  width: 80rpx;
  color: #334155;
  font-size: 27rpx;
  font-weight: 800;
}

.cover-wrap {
  position: relative;
}

.cover-image,
.add-cover {
  width: 150rpx;
  height: 150rpx;
  border-radius: 12rpx;
  background: #f1f5f9;
}

.add-cover {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx dashed #94a3b8;
  color: #64748b;
  font-size: 48rpx;
}

.text-preview {
  min-height: 180rpx;
  padding: 28rpx;
  border-radius: 16rpx;
  background: #f8fafc;
  color: #64748b;
  font-size: 28rpx;
  line-height: 1.7;
}

.form input {
  height: 84rpx;
  color: #10201d;
  font-size: 32rpx;
  font-weight: 800;
  border-bottom: 1rpx solid #eef2f7;
}

.form textarea {
  width: 100%;
  min-height: 260rpx;
  box-sizing: border-box;
  padding: 20rpx 0 8rpx;
  color: #334155;
  font-size: 28rpx;
  line-height: 1.7;
}

.section-title.compact {
  margin: 22rpx 0 14rpx;
  font-size: 26rpx;
}

.category-row,
.type-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.category-pill,
.type-pill {
  padding: 13rpx 20rpx;
  border-radius: 999rpx;
  background: #f8fafc;
  color: #475569;
  border: 1rpx solid #e2e8f0;
  font-size: 25rpx;
}

.category-pill.active,
.type-pill.active {
  background: #078894;
  color: #ffffff;
  border-color: #078894;
  font-weight: 800;
}

.extra-panel {
  padding: 18rpx 0 0;
  margin-top: 20rpx;
  border-top: 1rpx solid #eef2f7;
}

.extra-panel input {
  height: 72rpx;
  color: #334155;
  font-size: 27rpx;
  font-weight: 500;
}

.lost-kind {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.lost-kind view {
  flex: 1;
  height: 62rpx;
  line-height: 62rpx;
  text-align: center;
  border-radius: 10rpx;
  background: #f8fafc;
  color: #64748b;
  border: 1rpx solid #e2e8f0;
  font-size: 26rpx;
}

.lost-kind view.active {
  background: #078894;
  color: #ffffff;
  border-color: #078894;
  font-weight: 800;
}
