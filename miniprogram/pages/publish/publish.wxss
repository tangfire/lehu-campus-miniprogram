.section-title {
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.category-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.category-pill {
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #475569;
  border: 1rpx solid #e2e8f0;
  font-size: 26rpx;
}

.category-pill.active {
  background: #0f766e;
  color: #ffffff;
  border-color: #0f766e;
}

.form {
  padding: 24rpx;
}

.form input {
  height: 76rpx;
  font-size: 32rpx;
  font-weight: 700;
  border-bottom: 1rpx solid #e2e8f0;
}

.form textarea {
  width: 100%;
  min-height: 280rpx;
  box-sizing: border-box;
  padding-top: 20rpx;
  font-size: 28rpx;
  line-height: 1.7;
}

.submit {
  margin-top: 28rpx;
}

.image-picker {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid #e2e8f0;
}

.image-wrap {
  position: relative;
  width: 100%;
  height: 190rpx;
}

.picked-image,
.add-image {
  width: 100%;
  height: 190rpx;
  border-radius: 8rpx;
  background: #f1f5f9;
}

.add-image {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx dashed #94a3b8;
  color: #64748b;
  font-size: 54rpx;
}

.remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 38rpx;
  height: 38rpx;
  line-height: 36rpx;
  text-align: center;
  border-radius: 50%;
  background: rgba(15, 23, 42, 0.72);
  color: #ffffff;
  font-size: 28rpx;
}
