.section-title {
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.category-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.type-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-bottom: 24rpx;
}

.category-pill,
.type-pill {
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #475569;
  border: 1rpx solid #d9ecee;
  font-size: 26rpx;
}

.category-pill.active,
.type-pill.active {
  background: #078894;
  color: #ffffff;
  border-color: #078894;
}

.form {
  padding: 24rpx;
}

.form input {
  height: 76rpx;
  font-size: 32rpx;
  font-weight: 700;
  border-bottom: 1rpx solid #d9ecee;
}

.form textarea {
  width: 100%;
  min-height: 280rpx;
  box-sizing: border-box;
  padding-top: 20rpx;
  font-size: 28rpx;
  line-height: 1.7;
}

.extra-panel {
  padding: 18rpx 0 8rpx;
  border-top: 1rpx solid #d9ecee;
}

.extra-panel input {
  height: 72rpx;
  font-size: 27rpx;
  font-weight: 500;
}

.lost-kind {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.lost-kind view {
  flex: 1;
  height: 62rpx;
  line-height: 62rpx;
  text-align: center;
  border-radius: 8rpx;
  background: #f8fafc;
  color: #64748b;
  border: 1rpx solid #d9ecee;
  font-size: 26rpx;
}

.lost-kind view.active {
  background: #078894;
  color: #ffffff;
  border-color: #078894;
  font-weight: 700;
}

.media-tabs {
  display: flex;
  gap: 12rpx;
  padding-top: 22rpx;
  margin-top: 10rpx;
  border-top: 1rpx solid #d9ecee;
}

.media-tab {
  flex: 1;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  border-radius: 8rpx;
  background: #f8fafc;
  color: #64748b;
  border: 1rpx solid #d9ecee;
  font-size: 26rpx;
}

.media-tab.active {
  background: #078894;
  border-color: #078894;
  color: #ffffff;
  font-weight: 700;
}

.submit {
  margin-top: 28rpx;
}

.image-picker {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  padding-top: 18rpx;
}

.image-wrap {
  position: relative;
  width: 100%;
  height: 190rpx;
}

.picked-image,
.add-image {
  width: 100%;
  height: 190rpx;
  border-radius: 8rpx;
  background: #f1f5f9;
}

.add-image {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx dashed #94a3b8;
  color: #64748b;
  font-size: 54rpx;
}

.remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 38rpx;
  height: 38rpx;
  line-height: 36rpx;
  text-align: center;
  border-radius: 50%;
  background: rgba(15, 23, 42, 0.72);
  color: #ffffff;
  font-size: 28rpx;
}

.remove.small {
  width: 34rpx;
  height: 34rpx;
  line-height: 32rpx;
  font-size: 24rpx;
}

.video-picker {
  padding-top: 18rpx;
}

.video-wrap {
  position: relative;
}

.picked-video,
.add-video {
  width: 100%;
  height: 360rpx;
  border-radius: 8rpx;
  background: #0f172a;
  overflow: hidden;
}

.add-video {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  color: #d9ecee;
  font-size: 28rpx;
}

.add-video-icon {
  width: 72rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.16);
  font-size: 32rpx;
}

.cover-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 18rpx;
}

.cover-label {
  width: 80rpx;
  color: #334155;
  font-size: 27rpx;
  font-weight: 700;
}

.cover-wrap {
  position: relative;
}

.cover-image,
.add-cover {
  width: 150rpx;
  height: 150rpx;
  border-radius: 8rpx;
  background: #f1f5f9;
}

.add-cover {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx dashed #94a3b8;
  color: #64748b;
  font-size: 48rpx;
}
