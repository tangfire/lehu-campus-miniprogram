.tabs {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.tab {
  flex: 1;
  height: 68rpx;
  line-height: 68rpx;
  text-align: center;
  border-radius: 10rpx;
  background: #ffffff;
  color: #64748b;
  border: 1rpx solid #e2e8f0;
  font-size: 27rpx;
}

.tab.active {
  background: #0f766e;
  color: #ffffff;
  border-color: #0f766e;
}

.item {
  padding: 24rpx;
  margin-bottom: 18rpx;
}

.title {
  font-size: 31rpx;
  font-weight: 800;
}

.content {
  margin-top: 12rpx;
  color: #334155;
  font-size: 28rpx;
  line-height: 1.6;
}

.meta {
  margin-top: 14rpx;
  color: #64748b;
  font-size: 24rpx;
}

.actions {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

.actions button {
  flex: 1;
  height: 62rpx;
  line-height: 62rpx;
  border-radius: 8rpx;
  background: #eef7f5;
  color: #0f766e;
  font-size: 25rpx;
}

.actions .danger {
  background: #fef2f2;
  color: #dc2626;
}
