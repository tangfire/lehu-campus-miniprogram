.tabs {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.tab {
  flex: 1;
  height: 68rpx;
  line-height: 68rpx;
  text-align: center;
  border-radius: 10rpx;
  background: #ffffff;
  color: #64748b;
  border: 1rpx solid #ece7e2;
  font-size: 27rpx;
}

.tab.active {
  background: #ff4d5f;
  color: #ffffff;
  border-color: #ff4d5f;
}

.item {
  padding: 24rpx;
  margin-bottom: 18rpx;
}

.post-review {
  display: flex;
  gap: 18rpx;
}

.post-main {
  flex: 1;
  min-width: 0;
}

.thumb-wrap,
.text-thumb {
  position: relative;
  width: 132rpx;
  height: 132rpx;
  flex: none;
  border-radius: 8rpx;
  overflow: hidden;
  background: #f1f5f9;
}

.thumb {
  width: 100%;
  height: 100%;
}

.text-thumb {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ff4d5f;
  font-size: 42rpx;
  font-weight: 800;
}

.title {
  font-size: 31rpx;
  font-weight: 800;
}

.content {
  margin-top: 12rpx;
  color: #334155;
  font-size: 28rpx;
  line-height: 1.6;
}

.meta {
  margin-top: 14rpx;
  color: #64748b;
  font-size: 24rpx;
}

.actions {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

.actions button {
  flex: 1;
  height: 62rpx;
  line-height: 62rpx;
  border-radius: 8rpx;
  background: #fff1f3;
  color: #ff4d5f;
  font-size: 25rpx;
}

.actions .danger {
  background: #fef2f2;
  color: #dc2626;
}
