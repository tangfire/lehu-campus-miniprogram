.my-posts {
  padding-bottom: 48rpx;
  background: #f8f7f5;
}

.post {
  display: flex;
  gap: 18rpx;
  padding: 22rpx;
  margin-bottom: 16rpx;
  border-radius: 22rpx;
}

.thumb-wrap,
.text-thumb {
  position: relative;
  width: 132rpx;
  height: 132rpx;
  flex: none;
  border-radius: 16rpx;
  overflow: hidden;
  background: #f1f5f9;
}

.thumb {
  width: 100%;
  height: 100%;
}

.text-thumb {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ff4d5f;
  font-size: 42rpx;
  font-weight: 800;
}

.video-badge {
  position: absolute;
  left: 8rpx;
  bottom: 8rpx;
  width: 38rpx;
  height: 38rpx;
  line-height: 38rpx;
  text-align: center;
  border-radius: 50%;
  background: rgba(15, 23, 42, 0.72);
  color: #ffffff;
  font-size: 18rpx;
}

.post-main {
  flex: 1;
  min-width: 0;
}

.post-title {
  color: #18181b;
  font-size: 31rpx;
  font-weight: 800;
  line-height: 1.35;
}

.post-meta {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 24rpx;
}

.post-content {
  margin-top: 12rpx;
  color: #334155;
  font-size: 27rpx;
  line-height: 1.55;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.delete-btn {
  align-self: flex-start;
  margin: 0;
  width: 100rpx;
  height: 58rpx;
  line-height: 58rpx;
  border-radius: 999rpx;
  background: #fef2f2;
  color: #dc2626;
  font-size: 24rpx;
}
