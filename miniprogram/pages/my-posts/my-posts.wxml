<view class="page my-posts">
  <empty-state wx:if="{{!loading && posts.length === 0}}" title="还没有发布" desc="去社区发一条学习、生活或社团动态。" image="/assets/brand/empty/note.png" />

  <block wx:for="{{posts}}" wx:key="id">
    <view class="post panel">
      <view wx:if="{{item.display_cover}}" class="thumb-wrap" data-id="{{item.id}}" bindtap="openPost">
        <image class="thumb" src="{{item.display_cover}}" mode="aspectFill" />
        <view wx:if="{{item.media_type === 'video'}}" class="video-badge">▶</view>
      </view>
      <view wx:else class="text-thumb" data-id="{{item.id}}" bindtap="openPost">文</view>
      <view class="post-main" data-id="{{item.id}}" bindtap="openPost">
        <view class="post-title">{{item.title}}</view>
        <view class="post-meta">
          <text class="status-pill {{item.status_class}}">{{item.status_label}}</text>
          <text>{{item.category_name}} · {{item.type_label}} · {{item.created_at}}</text>
        </view>
        <view wx:if="{{item.status !== 1 && item.audit_reason}}" class="audit-reason">{{item.audit_reason}}</view>
        <view class="post-content">{{item.content}}</view>
      </view>
      <button class="delete-btn" data-id="{{item.id}}" catchtap="withdrawPost">撤回</button>
    </view>
  </block>
</view>
