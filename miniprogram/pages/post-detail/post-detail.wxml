<view class="page detail">
  <view wx:if="{{post}}" class="post">
    <view class="detail-nav" style="height: {{navBarHeight}}px; padding-top: {{statusBarHeight}}px;">
      <view class="back" bindtap="goBack"></view>
      <view class="nav-author">
        <image wx:if="{{post.author && post.author.avatar}}" class="nav-avatar" src="{{post.author.avatar}}" mode="aspectFill" />
        <view wx:else class="nav-avatar avatar-placeholder">{{post.avatar_text}}</view>
        <text>{{post.display_author}}</text>
      </view>
    </view>

    <video wx:if="{{post.media_type === 'video'}}" class="media-video" src="{{post.video_url}}" poster="{{post.cover_url}}" controls></video>
    <swiper wx:elif="{{post.images && post.images.length}}" class="media-swiper" indicator-dots circular>
      <block wx:for="{{post.images}}" wx:for-item="img" wx:key="*this">
        <swiper-item>
          <image class="media-image" src="{{img}}" mode="aspectFill" />
        </swiper-item>
      </block>
    </swiper>
    <view wx:else class="poster-hero {{post.poster_class}}">
      <view class="poster-kicker">{{post.poster_kicker}}</view>
      <view class="poster-title">{{post.poster_title}}</view>
    </view>

    <view class="post-main-card">
      <view class="post-head">
        <image wx:if="{{post.author && post.author.avatar}}" class="avatar" src="{{post.author.avatar}}" mode="aspectFill" />
        <view wx:else class="avatar avatar-placeholder">{{post.avatar_text}}</view>
        <view class="author-main">
          <view class="author-name">{{post.display_author}}</view>
          <view class="post-meta">{{post.category_name}} · {{post.display_time}}</view>
        </view>
        <view wx:if="{{post.is_official}}" class="follow-pill">官方</view>
        <view class="more" bindtap="openPostMenu">···</view>
      </view>

      <view class="title">{{post.title}}</view>
      <view class="tag-row">
        <text>{{post.short_type_label}}</text>
        <text wx:if="{{post.is_pinned}}">置顶</text>
        <text wx:if="{{post.is_featured}}">精选</text>
      </view>
      <view wx:if="{{post.extra_items && post.extra_items.length}}" class="extra-box">
        <view wx:for="{{post.extra_items}}" wx:key="label" class="extra-row">
          <text>{{item.label}}</text>
          <text>{{item.value}}</text>
        </view>
      </view>
      <view class="content">{{post.content}}</view>
    </view>
  </view>

  <view class="comment-title">共 {{post ? (post.comment_count || 0) : 0}} 条评论</view>
  <empty-state wx:if="{{comments.length === 0}}" title="暂无评论" desc="做第一个回应的同学。" />
  <view wx:if="{{comments.length}}" class="comment-compose">
    <view class="comment-smile">☺</view>
    <input value="{{commentText}}" bindinput="onInput" placeholder="爱评论的人运气都不差" confirm-type="send" bindconfirm="submitComment" maxlength="500" />
    <button bindtap="submitComment">发</button>
  </view>
  <block wx:for="{{comments}}" wx:key="id">
    <view class="comment">
      <view class="post-head">
        <image wx:if="{{item.author && item.author.avatar}}" class="avatar small" src="{{item.author.avatar}}" mode="aspectFill" />
        <view wx:else class="avatar small avatar-placeholder">{{item.avatar_text}}</view>
        <view class="author-main">
          <view class="author-name">{{item.display_author}}</view>
          <view class="post-meta">{{item.display_time}}</view>
        </view>
        <button wx:if="{{item.author && item.author.user_id === currentUserId}}" class="mini-action danger" data-id="{{item.id}}" bindtap="withdrawComment">撤回</button>
        <button wx:else class="mini-action" data-id="{{item.id}}" bindtap="reportComment">举报</button>
      </view>
      <view class="comment-content">{{item.content}}</view>
    </view>
  </block>

  <view class="comment-safe"></view>
  <view wx:if="{{post}}" class="comment-bar">
    <view class="bottom-input">
      <input value="{{commentText}}" bindinput="onInput" placeholder="说点什么..." confirm-type="send" bindconfirm="submitComment" maxlength="500" />
    </view>
    <view class="bottom-action {{post.is_liked ? 'active' : ''}}" bindtap="toggleLike">
      <text>{{post.is_liked ? '已赞' : '赞'}}</text>
      <text>{{post.like_count || 0}}</text>
    </view>
    <view class="bottom-action {{post.is_collected ? 'active star' : ''}}" bindtap="toggleCollection">
      <text>{{post.is_collected ? '已藏' : '藏'}}</text>
      <text>{{post.collected_count || 0}}</text>
    </view>
    <view class="bottom-action">
      <text>评论</text>
      <text>{{post.comment_count || 0}}</text>
    </view>
  </view>
</view>
