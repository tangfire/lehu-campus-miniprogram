.detail {
  padding: 0 0 48rpx;
  background: #ffffff;
}

.post {
  margin-bottom: 18rpx;
}

.media-video,
.media-swiper {
  width: 100%;
  height: 650rpx;
  overflow: hidden;
  background: #0f172a;
}

.media-image {
  width: 100%;
  height: 100%;
}

.post-main-card {
  padding: 26rpx 28rpx 18rpx;
  background: #ffffff;
}

.post-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.author-main {
  flex: 1;
  min-width: 0;
}

.more {
  width: 44rpx;
  height: 44rpx;
  line-height: 34rpx;
  text-align: center;
  color: #64748b;
  font-size: 34rpx;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #dbeafe;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #078894;
  font-size: 28rpx;
  font-weight: 800;
}

.avatar.small {
  width: 58rpx;
  height: 58rpx;
}

.author-name {
  font-size: 28rpx;
  font-weight: 800;
  color: #10201d;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.post-meta {
  color: #64748b;
  font-size: 23rpx;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.type-tag {
  flex: none;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #e8f8f8;
  color: #078894;
  font-size: 22rpx;
  font-weight: 800;
}

.title {
  margin-top: 30rpx;
  color: #10201d;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1.35;
}

.extra-box {
  margin-top: 20rpx;
  padding: 4rpx 22rpx;
  border-radius: 12rpx;
  background: #f7fbfb;
}

.extra-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #d9ecee;
  font-size: 26rpx;
}

.extra-row:last-child {
  border-bottom: 0;
}

.extra-row text:first-child {
  color: #64748b;
}

.extra-row text:last-child {
  color: #10201d;
  text-align: right;
  font-weight: 700;
}

.content,
.comment-content {
  margin-top: 18rpx;
  color: #334155;
  font-size: 30rpx;
  line-height: 1.78;
  white-space: pre-wrap;
}

.action-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 28rpx;
  color: #64748b;
}

.action {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  min-width: 104rpx;
  height: 58rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #f7fbfb;
  color: #078894;
  font-size: 25rpx;
  font-weight: 800;
  box-sizing: border-box;
}

.action.liked {
  background: #078894;
  color: #ffffff;
}

.action.collected {
  background: #fff7ed;
  color: #ea580c;
}

.action.plain {
  color: #64748b;
}

.comment-title {
  padding: 28rpx 28rpx 14rpx;
  border-top: 14rpx solid #f7fbfb;
  color: #10201d;
  font-size: 31rpx;
  font-weight: 900;
}

.comment {
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #eef6f6;
  background: #ffffff;
}

.comment .post-head {
  align-items: flex-start;
}

.comment-content {
  margin-left: 74rpx;
  margin-top: 8rpx;
  font-size: 28rpx;
  line-height: 1.65;
}

.mini-action {
  margin: 0;
  width: 88rpx;
  height: 52rpx;
  line-height: 52rpx;
  border-radius: 8rpx;
  background: #f1f5f9;
  color: #64748b;
  font-size: 23rpx;
}

.mini-action.danger {
  background: #fef2f2;
  color: #dc2626;
}

.comment-safe {
  height: 118rpx;
}

.comment-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #e5f0f0;
  background: rgba(255, 255, 255, 0.96);
  box-sizing: border-box;
}

.comment-bar input {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #f1f7f7;
  color: #10201d;
  font-size: 27rpx;
  box-sizing: border-box;
}

.comment-bar button {
  flex: none;
  width: 112rpx;
  height: 70rpx;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  background: #078894;
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 70rpx;
}
