.detail {
  min-height: 100vh;
  padding: 0;
  background: #ffffff;
}

.post {
  background: #ffffff;
}

.detail-nav {
  position: sticky;
  top: 0;
  z-index: 12;
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 100rpx;
  padding-left: 28rpx;
  padding-right: 28rpx;
  border-bottom: 1rpx solid rgba(15, 23, 42, 0.05);
  background: rgba(255, 255, 255, 0.98);
  box-sizing: border-box;
}

.back {
  position: relative;
  width: 48rpx;
  height: 48rpx;
  flex: none;
}

.back::before {
  content: "";
  position: absolute;
  left: 16rpx;
  top: 10rpx;
  width: 24rpx;
  height: 24rpx;
  border-left: 4rpx solid #111827;
  border-bottom: 4rpx solid #111827;
  border-radius: 2rpx;
  transform: rotate(45deg);
}

.nav-author {
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex: 1;
  min-width: 0;
  color: #1f2937;
  font-size: 29rpx;
  font-weight: 700;
}

.nav-author text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nav-avatar {
  width: 62rpx;
  height: 62rpx;
  border-radius: 50%;
  flex: none;
  background: #fff1f3;
}

.media-swiper {
  width: 100%;
  height: 660rpx;
  overflow: hidden;
  background: #0f172a;
}

.media-image {
  width: 100%;
  height: 100%;
}

.poster-hero {
  position: relative;
  min-height: 560rpx;
  display: flex;
  align-items: center;
  padding: 92rpx 58rpx 72rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.poster-mint {
  background: #effcf5;
}

.poster-lemon {
  background: #fff9d7;
}

.poster-rose {
  background: #fff0f4;
}

.poster-sky {
  background: #eff6ff;
}

.poster-paper {
  background: #f8f1e8;
}

.poster-title {
  position: relative;
  color: #222222;
  font-size: 58rpx;
  font-weight: 900;
  line-height: 1.32;
  letter-spacing: 0;
}

.post-main-card {
  padding: 30rpx 30rpx 32rpx;
  background: #ffffff;
}

.post-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.author-main {
  flex: 1;
  min-width: 0;
}

.more {
  width: 52rpx;
  height: 52rpx;
  line-height: 40rpx;
  text-align: center;
  color: #9ca3af;
  font-size: 36rpx;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #fff1f3;
  flex: none;
}

.official-avatar {
  background: #fff7f8;
  box-shadow: 0 4rpx 12rpx rgba(255, 77, 95, 0.12);
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ff4d5f;
  font-size: 28rpx;
  font-weight: 800;
}

.avatar.small {
  width: 66rpx;
  height: 66rpx;
}

.author-name {
  font-size: 29rpx;
  font-weight: 800;
  color: #111827;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.post-meta {
  color: #8b95a5;
  font-size: 23rpx;
  margin-top: 5rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.follow-pill {
  flex: none;
  height: 54rpx;
  line-height: 54rpx;
  padding: 0 24rpx;
  border: 1rpx solid rgba(239, 64, 86, 0.28);
  border-radius: 999rpx;
  color: #ff4d5f;
  font-size: 25rpx;
  font-weight: 800;
}

.sync-status {
  margin-top: 24rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #fffbeb;
  color: #92400e;
}

.sync-status.state-needs_attention,
.sync-status.state-hidden {
  background: #fef2f2;
  color: #b91c1c;
}

.sync-status view:first-child {
  font-size: 25rpx;
  font-weight: 900;
  line-height: 1.35;
}

.sync-status view:last-child {
  margin-top: 6rpx;
  font-size: 23rpx;
  line-height: 1.45;
}

.title {
  margin-top: 30rpx;
  color: #222222;
  font-size: 35rpx;
  font-weight: 800;
  line-height: 1.42;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.tag-row text {
  height: 32rpx;
  line-height: 32rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: #faf9f7;
  color: #6b7280;
  font-size: 21rpx;
  font-weight: 700;
}

.extra-box {
  margin-top: 22rpx;
  padding: 4rpx 22rpx;
  border-radius: 20rpx;
  background: #faf9f7;
}

.extra-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 17rpx 0;
  border-bottom: 1rpx solid #f1ede8;
  font-size: 26rpx;
}

.extra-row:last-child {
  border-bottom: 0;
}

.extra-row text:first-child {
  color: #8b95a5;
}

.extra-row text:last-child {
  color: #111827;
  text-align: right;
  font-weight: 700;
}

.content {
  margin-top: 22rpx;
  color: #333333;
  font-size: 29rpx;
  line-height: 1.72;
  white-space: pre-wrap;
}

.comment-title {
  padding: 28rpx 30rpx 18rpx;
  border-top: 12rpx solid #f8f7f5;
  color: #111827;
  font-size: 32rpx;
  font-weight: 800;
}

.sync-lock {
  margin: 24rpx 30rpx 40rpx;
  padding: 24rpx 26rpx;
  border-radius: 20rpx;
  background: #faf9f7;
  color: #64748b;
}

.sync-lock view:first-child {
  color: #111827;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.35;
}

.sync-lock view:last-child {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
}

.comment {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 24rpx 30rpx 26rpx;
  background: #ffffff;
}

.comment-avatar-wrap {
  flex: none;
  padding-top: 2rpx;
}

.comment-main {
  flex: 1;
  min-width: 0;
  padding-bottom: 18rpx;
  border-bottom: 1rpx solid #f5f1ed;
}

.comment-top {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}

.comment-body {
  flex: 1;
  min-width: 0;
}

.comment-author {
  color: #8b95a5;
  font-size: 24rpx;
  line-height: 1.35;
}

.comment-content {
  margin-top: 8rpx;
  color: #1f2937;
  font-size: 28rpx;
  line-height: 1.66;
  white-space: pre-wrap;
}

.comment-like {
  flex: none;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 48rpx;
  color: #9ca3af;
  font-size: 21rpx;
  line-height: 1.1;
}

.comment-like .heart {
  font-size: 38rpx;
  line-height: 38rpx;
}

.comment-like.active {
  color: #ff4d5f;
}

.comment-meta {
  display: flex;
  align-items: center;
  gap: 22rpx;
  margin-top: 10rpx;
  color: #9ca3af;
  font-size: 23rpx;
}

.comment-meta text:last-child {
  color: #6b7280;
  font-weight: 600;
}

.reply-list {
  margin-top: 16rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: #fafafa;
}

.reply-item + .reply-item {
  margin-top: 16rpx;
}

.reply-body {
  color: #374151;
  font-size: 25rpx;
  line-height: 1.58;
}

.reply-author {
  color: #687387;
  font-weight: 700;
}

.reply-prefix {
  color: #7b8494;
}

.reply-text {
  color: #2f3744;
}

.reply-foot {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 7rpx;
  color: #9ca3af;
  font-size: 22rpx;
}

.reply-like {
  margin-left: auto;
  color: #9ca3af;
}

.reply-like.active {
  color: #ff4d5f;
}

.expand-replies {
  display: inline-flex;
  align-items: center;
  margin-top: 14rpx;
  color: #6b7280;
  font-size: 24rpx;
  font-weight: 700;
}

.mini-action {
  margin: 0;
  width: 76rpx;
  height: 48rpx;
  line-height: 48rpx;
  border-radius: 999rpx;
  background: transparent;
  color: #9ca3af;
  font-size: 23rpx;
}

.mini-action.danger {
  color: #dc2626;
}

.comment-safe {
  height: 126rpx;
}

.comment-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx 24rpx calc(14rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f1ede8;
  background: rgba(255, 255, 255, 0.98);
  box-sizing: border-box;
}

.replying-strip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  padding: 0 8rpx 2rpx;
  color: #7b8494;
  font-size: 23rpx;
  box-sizing: border-box;
}

.replying-strip text:first-child {
  max-width: 520rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.replying-strip text:last-child {
  color: #ff4d5f;
  font-weight: 700;
}

.mention-panel {
  display: flex;
  align-items: center;
  gap: 16rpx;
  width: 100%;
  padding: 16rpx 18rpx;
  border-radius: 22rpx;
  background: #fff7f8;
  border: 1rpx solid rgba(255, 77, 95, 0.16);
  box-sizing: border-box;
}

.mention-avatar {
  width: 58rpx;
  height: 58rpx;
  border-radius: 18rpx;
  background: #ffffff;
  flex: none;
}

.mention-main {
  flex: 1;
  min-width: 0;
}

.mention-main view:first-child {
  color: #18181b;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 1.25;
}

.mention-main view:last-child {
  margin-top: 4rpx;
  color: #94a3b8;
  font-size: 22rpx;
  line-height: 1.3;
}

.mention-action {
  flex: none;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #ff4d5f;
  color: #ffffff;
  font-size: 23rpx;
  font-weight: 900;
}

.bottom-input {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
  height: 70rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #f7f7f8;
  box-sizing: border-box;
}

.bottom-input input {
  flex: 1;
  min-width: 0;
  height: 70rpx;
  color: #111827;
  font-size: 27rpx;
}

.send-action {
  flex: none;
  width: 88rpx;
  height: 58rpx;
  line-height: 58rpx;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  background: #ff4d5f;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 900;
}

.send-action::after {
  border: 0;
}

.bottom-action {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 5rpx;
  flex: none;
  min-width: 86rpx;
  height: 58rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: #faf9f7;
  color: #64748b;
  font-size: 23rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.bottom-action text:first-child {
  color: #111827;
}

.bottom-action.active {
  background: #fff1f3;
  color: #ff4d5f;
}

.bottom-action.star {
  background: #fff7ed;
  color: #d97706;
}

.bottom-action.active text:first-child {
  color: inherit;
}
