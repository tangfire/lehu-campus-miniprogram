.detail {
  min-height: 100vh;
  padding: 0;
  background: #ffffff;
}

.post {
  background: #ffffff;
}

.detail-nav {
  position: sticky;
  top: 0;
  z-index: 12;
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 104rpx;
  padding-left: 28rpx;
  padding-right: 28rpx;
  border-bottom: 1rpx solid rgba(15, 23, 42, 0.06);
  background: rgba(255, 255, 255, 0.98);
  backdrop-filter: blur(18rpx);
  box-sizing: border-box;
}

.back {
  position: relative;
  width: 48rpx;
  height: 48rpx;
  flex: none;
}

.back::before {
  content: "";
  position: absolute;
  left: 16rpx;
  top: 10rpx;
  width: 24rpx;
  height: 24rpx;
  border-left: 5rpx solid #111827;
  border-bottom: 5rpx solid #111827;
  border-radius: 2rpx;
  transform: rotate(45deg);
}

.nav-author {
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex: 1;
  min-width: 0;
  color: #1f2937;
  font-size: 30rpx;
  font-weight: 700;
}

.nav-author text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nav-avatar {
  width: 62rpx;
  height: 62rpx;
  border-radius: 50%;
  flex: none;
  background: #e0f2fe;
}

.share-btn {
  position: relative;
  width: 60rpx;
  height: 60rpx;
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  flex: none;
}

.share-btn::before {
  content: "";
  position: absolute;
  left: 15rpx;
  top: 14rpx;
  width: 30rpx;
  height: 30rpx;
  border-top: 5rpx solid #111827;
  border-right: 5rpx solid #111827;
  border-radius: 3rpx;
  transform: rotate(45deg);
}

.share-btn::after {
  content: "";
  position: absolute;
  left: 14rpx;
  top: 29rpx;
  width: 30rpx;
  height: 5rpx;
  border-radius: 999rpx;
  background: #111827;
}

.media-video,
.media-swiper {
  width: 100%;
  height: 690rpx;
  overflow: hidden;
  background: #0f172a;
}

.media-image {
  width: 100%;
  height: 100%;
}

.poster-hero {
  position: relative;
  min-height: 670rpx;
  padding: 96rpx 68rpx 76rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.poster-mint {
  background: linear-gradient(160deg, #fbfff0 0%, #e7fff3 52%, #d7f2ed 100%);
}

.poster-lemon {
  background: linear-gradient(160deg, #ffffec 0%, #fff6bd 54%, #fffdf2 100%);
}

.poster-rose {
  background: linear-gradient(160deg, #fff5f7 0%, #ffdce4 54%, #fff8fa 100%);
}

.poster-sky {
  background: linear-gradient(160deg, #f6faff 0%, #dbeaff 54%, #f9fcff 100%);
}

.poster-paper {
  background: linear-gradient(160deg, #fffaf2 0%, #f2e7d6 54%, #fffdf8 100%);
}

.poster-quote {
  position: absolute;
  left: 72rpx;
  top: 56rpx;
  color: rgba(255, 255, 255, 0.7);
  font-size: 160rpx;
  font-weight: 900;
  line-height: 1;
}

.poster-orbit {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}

.poster-orbit.one {
  right: -80rpx;
  top: -70rpx;
  width: 230rpx;
  height: 230rpx;
  background: rgba(255, 255, 255, 0.42);
}

.poster-orbit.two {
  left: -72rpx;
  bottom: -82rpx;
  width: 190rpx;
  height: 190rpx;
  background: rgba(255, 255, 255, 0.34);
}

.poster-kicker {
  position: relative;
  display: inline-block;
  max-width: 100%;
  margin-bottom: 38rpx;
  padding: 9rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.66);
  color: #0f766e;
  font-size: 25rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.poster-title {
  position: relative;
  color: #333333;
  font-size: 64rpx;
  font-weight: 900;
  line-height: 1.28;
  letter-spacing: 0;
}

.poster-mark {
  position: absolute;
  right: 78rpx;
  bottom: 72rpx;
  width: 72rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: rgba(239, 64, 86, 0.38);
}

.post-main-card {
  padding: 30rpx 30rpx 28rpx;
  background: #ffffff;
}

.post-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.author-main {
  flex: 1;
  min-width: 0;
}

.more {
  width: 52rpx;
  height: 52rpx;
  line-height: 40rpx;
  text-align: center;
  color: #6b7280;
  font-size: 36rpx;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #e0f2fe;
  flex: none;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #0f766e;
  font-size: 28rpx;
  font-weight: 800;
}

.avatar.small {
  width: 66rpx;
  height: 66rpx;
}

.author-name {
  font-size: 29rpx;
  font-weight: 800;
  color: #111827;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.post-meta {
  color: #8b95a5;
  font-size: 23rpx;
  margin-top: 5rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.follow-pill {
  flex: none;
  height: 54rpx;
  line-height: 54rpx;
  padding: 0 24rpx;
  border: 1rpx solid rgba(239, 64, 86, 0.42);
  border-radius: 999rpx;
  color: #ef4056;
  font-size: 25rpx;
  font-weight: 800;
}

.title {
  margin-top: 34rpx;
  color: #222222;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.42;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.tag-row text {
  height: 32rpx;
  line-height: 32rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  color: #6b7280;
  font-size: 21rpx;
  font-weight: 700;
}

.extra-box {
  margin-top: 22rpx;
  padding: 4rpx 22rpx;
  border-radius: 16rpx;
  background: #f8fafc;
}

.extra-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 17rpx 0;
  border-bottom: 1rpx solid #e5e7eb;
  font-size: 26rpx;
}

.extra-row:last-child {
  border-bottom: 0;
}

.extra-row text:first-child {
  color: #8b95a5;
}

.extra-row text:last-child {
  color: #111827;
  text-align: right;
  font-weight: 700;
}

.content,
.comment-content {
  margin-top: 22rpx;
  color: #333333;
  font-size: 30rpx;
  line-height: 1.76;
  white-space: pre-wrap;
}

.comment-title {
  padding: 30rpx 30rpx 18rpx;
  border-top: 14rpx solid #f5f5f5;
  color: #111827;
  font-size: 32rpx;
  font-weight: 800;
}

.comment-compose {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 4rpx 30rpx 22rpx;
}

.comment-smile {
  flex: none;
  width: 62rpx;
  height: 62rpx;
  line-height: 62rpx;
  border-radius: 50%;
  background: #f8fafc;
  color: #8b95a5;
  text-align: center;
  font-size: 30rpx;
}

.comment-compose input {
  flex: 1;
  min-width: 0;
  height: 68rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  color: #111827;
  font-size: 26rpx;
  box-sizing: border-box;
}

.comment-compose button {
  flex: none;
  width: 72rpx;
  height: 64rpx;
  line-height: 64rpx;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  background: #ef4056;
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 800;
}

.comment {
  padding: 26rpx 30rpx 28rpx;
  background: #ffffff;
}

.comment .post-head {
  align-items: flex-start;
}

.comment-content {
  margin-left: 82rpx;
  margin-top: 8rpx;
  font-size: 29rpx;
  line-height: 1.64;
}

.mini-action {
  margin: 0;
  width: 76rpx;
  height: 48rpx;
  line-height: 48rpx;
  border-radius: 999rpx;
  background: transparent;
  color: #9ca3af;
  font-size: 23rpx;
}

.mini-action.danger {
  color: #dc2626;
}

.comment-safe {
  height: 126rpx;
}

.comment-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 16rpx 28rpx calc(16rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #eeeeee;
  background: rgba(255, 255, 255, 0.98);
  box-sizing: border-box;
}

.bottom-input {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
  height: 72rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  box-sizing: border-box;
}

.bottom-input input {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  color: #111827;
  font-size: 27rpx;
}

.pen-icon {
  position: relative;
  flex: none;
  width: 34rpx;
  height: 34rpx;
  margin-right: 14rpx;
  border-left: 5rpx solid #6b7280;
  border-bottom: 5rpx solid #6b7280;
  transform: rotate(-45deg);
}

.bottom-action {
  display: flex;
  align-items: center;
  gap: 7rpx;
  flex: none;
  color: #111827;
  font-size: 25rpx;
  font-weight: 700;
}

.heart-icon,
.star-icon,
.bubble-icon {
  position: relative;
  width: 42rpx;
  height: 42rpx;
  flex: none;
}

.heart-icon::before,
.heart-icon::after {
  content: "";
  position: absolute;
  top: 8rpx;
  width: 21rpx;
  height: 31rpx;
  border: 5rpx solid currentColor;
  border-bottom: 0;
  border-radius: 22rpx 22rpx 0 0;
  box-sizing: border-box;
}

.heart-icon::before {
  left: 5rpx;
  transform: rotate(-45deg);
}

.heart-icon::after {
  right: 5rpx;
  transform: rotate(45deg);
}

.star-icon::before {
  content: "☆";
  position: absolute;
  left: 0;
  top: -8rpx;
  color: currentColor;
  font-size: 54rpx;
  line-height: 1;
}

.bubble-icon {
  border: 5rpx solid currentColor;
  border-radius: 50%;
  box-sizing: border-box;
}

.bubble-icon::after {
  content: "";
  position: absolute;
  left: 5rpx;
  bottom: -3rpx;
  width: 12rpx;
  height: 12rpx;
  border-left: 5rpx solid currentColor;
  border-bottom: 5rpx solid currentColor;
  background: #ffffff;
  transform: rotate(-28deg);
}

.bottom-action.active {
  color: #ef4056;
}

.bottom-action.star {
  color: #f59e0b;
}
