.detail {
  padding-bottom: 48rpx;
}

.post,
.comment-box,
.comment {
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.media-video,
.media-swiper {
  width: 100%;
  height: 520rpx;
  margin-bottom: 24rpx;
  border-radius: 8rpx;
  overflow: hidden;
  background: #0f172a;
}

.media-image {
  width: 100%;
  height: 100%;
}

.post-head {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.author-main {
  flex: 1;
  min-width: 0;
}

.more {
  width: 58rpx;
  height: 58rpx;
  line-height: 48rpx;
  text-align: center;
  color: #64748b;
  font-size: 38rpx;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #dbeafe;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #0f766e;
  font-size: 28rpx;
  font-weight: 800;
}

.avatar.small {
  width: 58rpx;
  height: 58rpx;
}

.author-name {
  font-size: 28rpx;
  font-weight: 700;
}

.post-meta {
  color: #64748b;
  font-size: 24rpx;
  margin-top: 4rpx;
}

.title {
  margin-top: 26rpx;
  font-size: 38rpx;
  font-weight: 800;
}

.content,
.comment-content {
  margin-top: 16rpx;
  color: #334155;
  font-size: 29rpx;
  line-height: 1.75;
}

.action-row {
  display: flex;
  align-items: center;
  gap: 28rpx;
  margin-top: 22rpx;
  color: #64748b;
}

.action-row button {
  margin: 0;
  padding: 0 24rpx;
  height: 60rpx;
  line-height: 60rpx;
  border-radius: 10rpx;
  background: #eef7f5;
  color: #0f766e;
  font-size: 26rpx;
}

.action-row button.liked {
  background: #0f766e;
  color: #ffffff;
}

.comment-box textarea {
  width: 100%;
  min-height: 120rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}

.comment-box button {
  margin-top: 16rpx;
}

.comment-title {
  margin: 28rpx 0 16rpx;
  font-size: 32rpx;
  font-weight: 800;
}

.mini-action {
  margin: 0;
  width: 88rpx;
  height: 52rpx;
  line-height: 52rpx;
  border-radius: 8rpx;
  background: #f1f5f9;
  color: #64748b;
  font-size: 23rpx;
}

.mini-action.danger {
  background: #fef2f2;
  color: #dc2626;
}
