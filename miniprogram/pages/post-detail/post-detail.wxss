.detail {
  padding-bottom: 48rpx;
}

.post,
.comment-box,
.comment {
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.post-head {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #dbeafe;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #0f766e;
  font-size: 28rpx;
  font-weight: 800;
}

.avatar.small {
  width: 58rpx;
  height: 58rpx;
}

.author-name {
  font-size: 28rpx;
  font-weight: 700;
}

.post-meta {
  color: #64748b;
  font-size: 24rpx;
  margin-top: 4rpx;
}

.title {
  margin-top: 26rpx;
  font-size: 38rpx;
  font-weight: 800;
}

.content,
.comment-content {
  margin-top: 16rpx;
  color: #334155;
  font-size: 29rpx;
  line-height: 1.75;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin-top: 20rpx;
}

.post-image {
  width: 100%;
  height: 210rpx;
  border-radius: 8rpx;
  background: #e2e8f0;
}

.action-row {
  display: flex;
  align-items: center;
  gap: 28rpx;
  margin-top: 22rpx;
  color: #64748b;
}

.action-row button {
  margin: 0;
  padding: 0 24rpx;
  height: 60rpx;
  line-height: 60rpx;
  border-radius: 10rpx;
  background: #eef7f5;
  color: #0f766e;
  font-size: 26rpx;
}

.action-row button.liked {
  background: #0f766e;
  color: #ffffff;
}

.comment-box textarea {
  width: 100%;
  min-height: 120rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}

.comment-box button {
  margin-top: 16rpx;
}

.comment-title {
  margin: 28rpx 0 16rpx;
  font-size: 32rpx;
  font-weight: 800;
}
