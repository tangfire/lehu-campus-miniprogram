.help-detail-page {
  padding-bottom: 150rpx;
}

.summary,
.detail-card,
.flow-card,
.note-card {
  border-radius: 18rpx;
  padding: 30rpx;
}

.summary-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}

.author {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-width: 0;
}

.avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  flex: none;
}

.placeholder {
  background: #e2e8f0;
  color: #64748b;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 900;
}

.name {
  font-size: 29rpx;
  font-weight: 900;
  color: #0f172a;
}

.muted-text {
  margin-top: 5rpx;
  font-size: 23rpx;
  color: #94a3b8;
}

.reward-block {
  text-align: right;
  flex: none;
}

.reward-label {
  font-size: 24rpx;
  color: #475569;
}

.reward {
  margin-top: 4rpx;
  color: #ff4d5f;
  font-size: 38rpx;
  font-weight: 900;
}

.title {
  margin-top: 32rpx;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.4;
  color: #0f172a;
}

.content {
  margin-top: 16rpx;
  font-size: 29rpx;
  line-height: 1.65;
  color: #334155;
}

.status-line {
  margin-top: 28rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.status {
  border: 1rpx solid currentColor;
  border-radius: 8rpx;
  padding: 7rpx 14rpx;
  font-size: 24rpx;
}

.status.open {
  color: #2563eb;
}

.status.active,
.status.submitted {
  color: #0f766e;
}

.status.done {
  color: #16a34a;
}

.status.muted {
  color: #94a3b8;
}

.campus {
  color: #64748b;
  font-size: 25rpx;
}

.detail-card,
.flow-card,
.note-card {
  margin-top: 20rpx;
}

.row {
  min-height: 64rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 24rpx;
  font-size: 27rpx;
  color: #0f172a;
}

.row text:first-child {
  color: #64748b;
  flex: none;
}

.row text:last-child {
  text-align: right;
  word-break: break-all;
}

.flow-title {
  font-size: 28rpx;
  font-weight: 900;
  color: #0f172a;
}

.flow {
  margin-top: 28rpx;
  display: grid;
  grid-template-columns: 1fr 28rpx 1fr 28rpx 1fr 28rpx 1fr;
  align-items: center;
}

.flow-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  font-size: 22rpx;
  color: #64748b;
  text-align: center;
}

.flow-icon {
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  background: #eef2ff;
  color: #2563eb;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 900;
}

.flow-line {
  height: 2rpx;
  background: #cbd5e1;
}

.note-title {
  font-size: 27rpx;
  font-weight: 900;
  color: #0f172a;
}

.note-content {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #475569;
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -8rpx 24rpx rgba(15, 23, 42, 0.06);
  display: flex;
  gap: 16rpx;
}

.action-bar button {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
}

.loading-card {
  padding: 50rpx;
  text-align: center;
  color: #64748b;
}
