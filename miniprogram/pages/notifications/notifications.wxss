.notifications {
  min-height: 100vh;
  padding: 34rpx 26rpx 70rpx;
  background: #fbfbfa;
  box-sizing: border-box;
}

.head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.title {
  color: #172033;
  font-size: 48rpx;
  font-weight: 900;
  line-height: 1.1;
}

.subtitle {
  margin-top: 10rpx;
  color: #64748b;
  font-size: 25rpx;
}

.read-all {
  height: 62rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #fff1f3;
  color: #ff4d5f;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 62rpx;
}

.read-all::after {
  border: 0;
}

.tabs {
  margin: 0 -26rpx 20rpx;
  padding: 0 26rpx;
  box-sizing: border-box;
  white-space: nowrap;
}

.tab-row {
  display: inline-flex;
  gap: 16rpx;
  padding: 4rpx 26rpx 10rpx;
}

.tab {
  position: relative;
  display: flex;
  align-items: center;
  gap: 8rpx;
  height: 64rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #64748b;
  font-size: 26rpx;
  font-weight: 800;
  box-shadow: 0 8rpx 22rpx rgba(15, 23, 42, 0.05);
}

.tab.active {
  background: #ff4d5f;
  color: #ffffff;
}

.tab-dot {
  min-width: 28rpx;
  height: 28rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.95);
  color: #ff4d5f;
  font-size: 20rpx;
  line-height: 28rpx;
  text-align: center;
}

.list {
  display: grid;
  gap: 16rpx;
}

.item {
  display: flex;
  gap: 20rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.06);
}

.item.read {
  opacity: 0.68;
}

.icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #ff6b7b, #ff9aa7);
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 64rpx;
  text-align: center;
  flex: none;
}

.body {
  flex: 1;
  min-width: 0;
}

.row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.item-title {
  color: #111827;
  font-size: 29rpx;
  font-weight: 900;
  line-height: 1.35;
  flex: 1;
}

.dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #ff4d5f;
  flex: none;
}

.content {
  margin-top: 10rpx;
  color: #334155;
  font-size: 26rpx;
  line-height: 1.55;
  word-break: break-all;
}

.meta {
  margin-top: 14rpx;
  color: #94a3b8;
  font-size: 23rpx;
}

.loading {
  padding: 36rpx 0;
  color: #94a3b8;
  font-size: 25rpx;
  text-align: center;
}
