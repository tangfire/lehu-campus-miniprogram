.about {
  padding: 34rpx 38rpx 64rpx;
  background: #f8f7f5;
}

.intro {
  display: flex;
  align-items: center;
  gap: 22rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 30rpx rgba(15, 23, 42, 0.04);
}

.logo {
  width: 108rpx;
  height: 108rpx;
  border-radius: 28rpx;
  background: #fff7f8;
  flex: none;
  box-shadow: 0 8rpx 20rpx rgba(255, 77, 95, 0.1);
}

.name {
  color: #18181b;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.25;
}

.tagline {
  margin-top: 10rpx;
  color: #64748b;
  font-size: 25rpx;
  line-height: 1.45;
}

.ip-card {
  position: relative;
  display: flex;
  align-items: center;
  gap: 22rpx;
  min-height: 212rpx;
  padding: 22rpx 28rpx;
  margin-bottom: 20rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #fff8f7, #effaff);
  box-shadow: 0 10rpx 28rpx rgba(255, 77, 95, 0.06);
  box-sizing: border-box;
  overflow: hidden;
}

.ip-art {
  align-self: flex-end;
  width: 132rpx;
  height: 188rpx;
  flex: none;
}

.ip-copy {
  flex: 1;
  min-width: 0;
}

.ip-title {
  color: #18181b;
  font-size: 31rpx;
  font-weight: 900;
}

.ip-desc {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.55;
}

.section {
  padding: 28rpx;
  margin-bottom: 18rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border-top: 0;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.035);
}

.section-title {
  margin-bottom: 22rpx;
  color: #18181b;
  font-size: 32rpx;
  font-weight: 900;
}

.paragraph {
  color: #3f3f46;
  font-size: 29rpx;
  line-height: 1.82;
}

.paragraph + .paragraph {
  margin-top: 20rpx;
}

.muted {
  color: #64748b;
}

.info-row {
  display: flex;
  align-items: flex-start;
  gap: 34rpx;
  padding: 16rpx 0;
  font-size: 28rpx;
  line-height: 1.55;
}

.info-row text:first-child {
  width: 150rpx;
  flex: none;
  color: #94a3b8;
}

.info-row text:last-child {
  flex: 1;
  min-width: 0;
  color: #18181b;
}

.service-list {
  display: grid;
  gap: 16rpx;
}

.service-list view {
  position: relative;
  padding-left: 28rpx;
  color: #3f3f46;
  font-size: 28rpx;
  line-height: 1.7;
}

.service-list view::before {
  content: "";
  position: absolute;
  left: 0;
  top: 20rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #ff4d5f;
}

.copy-btn {
  height: 72rpx;
  margin: 28rpx 0 0;
  border-radius: 999rpx;
  background: #fff1f3;
  color: #ff4d5f;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 72rpx;
}

.policy-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f1ede8;
}

.policy-row:last-child {
  border-bottom: 0;
}

.policy-row text:first-child {
  color: #18181b;
  font-size: 28rpx;
  font-weight: 900;
}

.policy-row text:last-child {
  color: #94a3b8;
  font-size: 24rpx;
}
