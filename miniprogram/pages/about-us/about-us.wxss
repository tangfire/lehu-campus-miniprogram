.about {
  min-height: 100vh;
  padding: 30rpx 36rpx 70rpx;
  background: #fffaf8;
  box-sizing: border-box;
}

.hero {
  position: relative;
  min-height: 238rpx;
  padding: 34rpx 32rpx 32rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #fff2f1 0%, #ffffff 54%, #edf9ff 100%);
  overflow: hidden;
  box-sizing: border-box;
}

.brand-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.logo {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  background: #ffffff;
  flex: none;
  box-shadow: 0 10rpx 24rpx rgba(255, 77, 95, 0.12);
}

.name {
  color: #18181b;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1.2;
}

.tagline {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.4;
}

.hero-copy {
  position: relative;
  z-index: 1;
  margin-top: 28rpx;
  color: #3f3f46;
  font-size: 28rpx;
  line-height: 1.68;
}

.notice {
  display: flex;
  gap: 18rpx;
  margin: 24rpx 0 10rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(15, 23, 42, 0.08);
}

.notice text:first-child {
  flex: none;
  color: #ff4d5f;
  font-size: 25rpx;
  font-weight: 900;
}

.notice text:last-child {
  color: #64748b;
  font-size: 25rpx;
  line-height: 1.55;
}

.section {
  padding: 30rpx 0;
  border-bottom: 1rpx solid rgba(15, 23, 42, 0.08);
}

.section:last-child {
  border-bottom: 0;
}

.section-title {
  margin-bottom: 18rpx;
  color: #18181b;
  font-size: 31rpx;
  font-weight: 900;
}

.paragraph {
  color: #3f3f46;
  font-size: 28rpx;
  line-height: 1.78;
}

.muted {
  color: #64748b;
}

.list-row {
  display: flex;
  align-items: flex-start;
  gap: 28rpx;
  padding: 14rpx 0;
  line-height: 1.55;
}

.list-row text:first-child {
  width: 132rpx;
  flex: none;
  color: #94a3b8;
  font-size: 26rpx;
}

.list-row text:last-child {
  flex: 1;
  min-width: 0;
  color: #27272a;
  font-size: 28rpx;
}

.ezai-card {
  position: relative;
  padding: 28rpx 26rpx 30rpx;
  border-radius: 26rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fff5f6 100%);
  box-shadow: 0 10rpx 28rpx rgba(255, 77, 95, 0.08);
  box-sizing: border-box;
  overflow: hidden;
}

.ezai-grid {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.ezai-copy {
  flex: 1;
  min-width: 0;
}

.ezai-name {
  color: #18181b;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.2;
}

.ezai-role {
  display: inline-flex;
  margin-top: 10rpx;
  padding: 7rpx 16rpx;
  border-radius: 999rpx;
  background: #ffe5e9;
  color: #ff4d5f;
  font-size: 23rpx;
  font-weight: 800;
}

.ezai-sticker {
  width: 190rpx;
  height: 220rpx;
  margin-top: -12rpx;
  margin-right: -18rpx;
  flex: none;
}

.ezai-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 22rpx;
}

.ezai-tags text {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #fff1f3;
  color: #ff4d5f;
  font-size: 24rpx;
  font-weight: 800;
}

.policy-section {
  padding-bottom: 8rpx;
}

.policy-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 22rpx 0;
}

.policy-row + .policy-row {
  border-top: 1rpx solid rgba(15, 23, 42, 0.06);
}

.policy-row text:first-child {
  color: #18181b;
  font-size: 28rpx;
  font-weight: 900;
}

.policy-row text:last-child {
  color: #94a3b8;
  font-size: 24rpx;
}
