.about {
  padding: 34rpx 38rpx 64rpx;
  background: #ffffff;
}

.intro {
  display: flex;
  align-items: center;
  gap: 22rpx;
  padding: 18rpx 0 42rpx;
}

.logo {
  width: 108rpx;
  height: 108rpx;
  border-radius: 24rpx;
  background: #f7fbfb;
  flex: none;
}

.name {
  color: #10201d;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.25;
}

.tagline {
  margin-top: 10rpx;
  color: #64748b;
  font-size: 25rpx;
  line-height: 1.45;
}

.section {
  padding: 34rpx 0;
  border-top: 1rpx solid #edf4f4;
}

.section-title {
  margin-bottom: 22rpx;
  color: #10201d;
  font-size: 32rpx;
  font-weight: 900;
}

.paragraph {
  color: #263734;
  font-size: 29rpx;
  line-height: 1.82;
}

.paragraph + .paragraph {
  margin-top: 20rpx;
}

.muted {
  color: #64748b;
}

.info-row {
  display: flex;
  align-items: flex-start;
  gap: 34rpx;
  padding: 16rpx 0;
  font-size: 28rpx;
  line-height: 1.55;
}

.info-row text:first-child {
  width: 150rpx;
  flex: none;
  color: #94a3b8;
}

.info-row text:last-child {
  flex: 1;
  min-width: 0;
  color: #10201d;
}

.service-list {
  display: grid;
  gap: 16rpx;
}

.service-list view {
  position: relative;
  padding-left: 28rpx;
  color: #263734;
  font-size: 28rpx;
  line-height: 1.7;
}

.service-list view::before {
  content: "";
  position: absolute;
  left: 0;
  top: 20rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #078894;
}

.copy-btn {
  height: 72rpx;
  margin: 28rpx 0 0;
  border-radius: 999rpx;
  background: #e8f8f8;
  color: #078894;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 72rpx;
}
