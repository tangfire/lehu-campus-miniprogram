page {
  background: #f8f7f5;
  color: #18181b;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx;
}

.panel {
  background: #ffffff;
  border: 1rpx solid rgba(15, 23, 42, 0.04);
  border-radius: 22rpx;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.035);
}

.primary-btn {
  background: #ff4d5f;
  color: #ffffff;
  border-radius: 999rpx;
  font-weight: 800;
  box-shadow: 0 10rpx 24rpx rgba(255, 77, 95, 0.18);
}

.ghost-btn {
  background: #fff1f3;
  color: #ff4d5f;
  border-radius: 999rpx;
  font-weight: 800;
}

.muted {
  color: #64748b;
}

button::after {
  border: 0;
}

.brand-logo {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  background: #ffffff;
  flex: none;
}

.brand-card {
  background: #ffffff;
  border: 1rpx solid rgba(15, 23, 42, 0.04);
  border-radius: 22rpx;
}
