page {
  background: #f4fafa;
  color: #10201d;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx;
}

.panel {
  background: #ffffff;
  border: 1rpx solid #d9ecee;
  border-radius: 12rpx;
}

.primary-btn {
  background: #078894;
  color: #ffffff;
  border-radius: 10rpx;
}

.ghost-btn {
  background: #e8f8f8;
  color: #078894;
  border-radius: 10rpx;
}

.muted {
  color: #64748b;
}

button::after {
  border: 0;
}

.brand-logo {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  background: #ffffff;
  flex: none;
}

.brand-card {
  background: #ffffff;
  border: 1rpx solid #d9ecee;
  border-radius: 14rpx;
}
