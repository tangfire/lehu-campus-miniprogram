page {
  background: #f5f7f8;
  color: #10201d;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx;
}

.panel {
  background: #ffffff;
  border: 1rpx solid #e2e8f0;
  border-radius: 12rpx;
}

.primary-btn {
  background: #0f766e;
  color: #ffffff;
  border-radius: 10rpx;
}

.ghost-btn {
  background: #eef7f5;
  color: #0f766e;
  border-radius: 10rpx;
}

.muted {
  color: #64748b;
}
