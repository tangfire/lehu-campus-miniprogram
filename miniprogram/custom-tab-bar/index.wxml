<view class="tab-shell">
  <view class="tab-bar">
    <view class="tab-item {{selected === 0 ? 'active' : ''}}" data-index="0" bindtap="switchTab">
      <view class="tab-icon icon-home">
        <view class="home-roof"></view>
        <view class="home-body"></view>
      </view>
      <view class="tab-text">首页</view>
    </view>

    <view class="tab-item {{selected === 1 ? 'active' : ''}}" data-index="1" bindtap="switchTab">
      <view class="tab-icon icon-guide">
        <view class="guide-pin"></view>
        <view class="guide-line one"></view>
        <view class="guide-line two"></view>
      </view>
      <view class="tab-text">新生指引</view>
    </view>

    <view class="tab-item publish-slot" bindtap="goPublish" aria-role="button" aria-label="发布">
      <view class="publish-button">
        <view class="publish-line horizontal"></view>
        <view class="publish-line vertical"></view>
      </view>
      <view class="tab-text publish-text">发布</view>
    </view>

    <view class="tab-item {{selected === 2 ? 'active' : ''}}" data-index="2" bindtap="switchTab">
      <view class="tab-icon icon-calendar">
        <view class="calendar-ring left"></view>
        <view class="calendar-ring right"></view>
        <view class="calendar-line"></view>
      </view>
      <view class="tab-text">课表</view>
    </view>

    <view class="tab-item {{selected === 3 ? 'active' : ''}}" data-index="3" bindtap="switchTab">
      <view class="tab-icon icon-user">
        <view class="user-head"></view>
        <view class="user-body"></view>
      </view>
      <view class="tab-text">我的</view>
    </view>
  </view>
</view>
