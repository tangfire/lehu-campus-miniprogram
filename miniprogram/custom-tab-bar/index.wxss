.tab-shell {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 99;
  padding-bottom: env(safe-area-inset-bottom);
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid rgba(15, 23, 42, 0.08);
  box-shadow: 0 -10rpx 30rpx rgba(15, 23, 42, 0.06);
}

.tab-bar {
  position: relative;
  height: 112rpx;
}

.tab-item {
  position: absolute;
  top: 14rpx;
  width: 132rpx;
  height: 86rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 7rpx;
  color: #64748b;
}

.tab-home {
  left: 34rpx;
}

.tab-timetable {
  right: 166rpx;
}

.tab-mine {
  right: 24rpx;
}

.tab-item.active {
  color: #078894;
  font-weight: 800;
}

.tab-icon {
  position: relative;
  width: 40rpx;
  height: 40rpx;
  box-sizing: border-box;
}

.icon-home {
  border: 4rpx solid currentColor;
  border-top: 0;
  border-radius: 5rpx;
  transform: translateY(8rpx);
}

.icon-home::before {
  content: "";
  position: absolute;
  left: 4rpx;
  top: -14rpx;
  width: 24rpx;
  height: 24rpx;
  border-left: 4rpx solid currentColor;
  border-top: 4rpx solid currentColor;
  transform: rotate(45deg);
  border-radius: 3rpx;
}

.icon-calendar {
  border: 4rpx solid currentColor;
  border-radius: 8rpx;
}

.icon-calendar::before {
  content: "";
  position: absolute;
  left: -4rpx;
  right: -4rpx;
  top: 9rpx;
  height: 4rpx;
  background: currentColor;
}

.icon-calendar::after {
  content: "";
  position: absolute;
  left: 8rpx;
  top: -9rpx;
  width: 18rpx;
  height: 10rpx;
  border-left: 4rpx solid currentColor;
  border-right: 4rpx solid currentColor;
}

.icon-user {
  border: 4rpx solid currentColor;
  border-radius: 50%;
}

.icon-user::after {
  content: "";
  position: absolute;
  left: -8rpx;
  right: -8rpx;
  bottom: -15rpx;
  height: 18rpx;
  border: 4rpx solid currentColor;
  border-top: 0;
  border-radius: 0 0 20rpx 20rpx;
}

.tab-text {
  font-size: 22rpx;
  line-height: 1;
}

.publish-button {
  position: absolute;
  left: 50%;
  top: -22rpx;
  width: 116rpx;
  height: 116rpx;
  border-radius: 50%;
  background: #078894;
  color: #ffffff;
  transform: translateX(-50%);
  box-shadow: 0 16rpx 34rpx rgba(7, 136, 148, 0.28);
  display: flex;
  align-items: center;
  justify-content: center;
}

.publish-button::after {
  content: "";
  position: absolute;
  inset: 8rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.34);
  border-radius: 50%;
}

.publish-plus {
  position: relative;
  z-index: 1;
  margin-top: -4rpx;
  font-size: 66rpx;
  font-weight: 300;
  line-height: 1;
}
