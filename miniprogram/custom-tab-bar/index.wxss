.tab-shell {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 99;
  padding-bottom: env(safe-area-inset-bottom);
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid rgba(15, 23, 42, 0.06);
  box-shadow: 0 -10rpx 30rpx rgba(15, 23, 42, 0.05);
  backdrop-filter: blur(18rpx);
}

.tab-bar {
  height: 112rpx;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  align-items: center;
  padding: 6rpx 10rpx 0;
  box-sizing: border-box;
}

.tab-item {
  height: 96rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  color: #64748b;
  min-width: 0;
}

.tab-item.active {
  color: #ff4d5f;
  font-weight: 800;
}

.tab-icon {
  position: relative;
  width: 44rpx;
  height: 44rpx;
  box-sizing: border-box;
}

.home-roof {
  position: absolute;
  left: 9rpx;
  top: 4rpx;
  width: 26rpx;
  height: 26rpx;
  border-left: 3rpx solid currentColor;
  border-top: 3rpx solid currentColor;
  border-radius: 4rpx 0 0 0;
  transform: rotate(45deg);
}

.home-body {
  position: absolute;
  left: 8rpx;
  right: 8rpx;
  bottom: 4rpx;
  height: 26rpx;
  border: 3rpx solid currentColor;
  border-top: 0;
  border-radius: 5rpx;
}

.icon-calendar {
  border: 3rpx solid currentColor;
  border-radius: 10rpx;
}

.calendar-line {
  position: absolute;
  left: -3rpx;
  right: -3rpx;
  top: 13rpx;
  height: 3rpx;
  background: currentColor;
}

.calendar-ring {
  position: absolute;
  top: -9rpx;
  width: 3rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: currentColor;
}

.calendar-ring.left {
  left: 11rpx;
}

.calendar-ring.right {
  right: 11rpx;
}

.user-head {
  position: absolute;
  left: 11rpx;
  top: 4rpx;
  width: 24rpx;
  height: 24rpx;
  border: 3rpx solid currentColor;
  border-radius: 50%;
  box-sizing: border-box;
}

.user-body {
  position: absolute;
  left: 5rpx;
  right: 5rpx;
  bottom: 2rpx;
  height: 20rpx;
  border: 3rpx solid currentColor;
  border-radius: 22rpx 22rpx 10rpx 10rpx;
  box-sizing: border-box;
}

.tab-text {
  max-width: 100%;
  font-size: 21rpx;
  line-height: 1;
  white-space: nowrap;
}

.publish-slot {
  color: #ff4d5f;
}

.publish-button {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #ff4d5f;
  color: #ffffff;
  box-shadow: 0 10rpx 22rpx rgba(255, 77, 95, 0.22);
  display: flex;
  align-items: center;
  justify-content: center;
}

.publish-button::after {
  content: "";
  position: absolute;
  inset: 6rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 50%;
}

.publish-line {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 31rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: #ffffff;
  transform: translate(-50%, -50%);
}

.publish-line.vertical {
  width: 4rpx;
  height: 31rpx;
}

.publish-text {
  color: #ff4d5f;
  font-weight: 800;
}
